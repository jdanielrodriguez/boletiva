# =====================================================================
# Pasa Eventos — PLANTILLA de variables de PRODUCCIÓN
# Copia a .env.prod (que NO se versiona) y llena con credenciales reales.
# .env.prod es la fuente para crear los secretos en GCP Secret Manager
# (ver docs/DESPLIEGUE.md). NUNCA subir credenciales al repo.
# =====================================================================

NODE_ENV=production
PORT=8080
APP_NAME=PasaEventos
TZ=America/Guatemala

# --- Base de datos (Cloud SQL for PostgreSQL) ---
# Con Cloud SQL Auth Proxy / IP privada. sslmode=require en conexión directa.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public&sslmode=require

# --- Redis (Memorystore) ---
REDIS_URL=rediss://:PASSWORD@HOST:6379

# --- RabbitMQ (CloudAMQP u operado) ---
AMQP_URL=amqps://USER:PASSWORD@HOST/VHOST

# --- Almacenamiento: GCS en prod ---
STORAGE_PROVIDER=gcs
GCLOUD_PROJECT_ID=pasa-eventos
GCS_BUCKET=pasaeventos-prod-media
# El JSON del service account NO va aquí en texto: se monta como secreto
# (GCS_SERVICE_ACCOUNT_JSON) o se usa Workload Identity en Cloud Run.
GCS_SERVICE_ACCOUNT_JSON=

# --- Correo (SendGrid / SES / SMTP) ---
MAIL_HOST=smtp.PROVEEDOR.com
MAIL_PORT=587
MAIL_USER=apikey-o-usuario
MAIL_PASS=CAMBIAR
MAIL_SECURE=true
MAIL_FROM=no-reply@pasaeventos.com

# --- Auth: secretos FUERTES y ÚNICOS (generar con openssl rand -base64 48) ---
JWT_ACCESS_SECRET=CAMBIAR
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=CAMBIAR
JWT_REFRESH_TTL=1209600

# --- Firma de boletos Ed25519 (Ola 4) ---
TICKET_SIGNING_PRIVATE_KEY=CAMBIAR_base64
TICKET_SIGNING_PUBLIC_KEY=CAMBIAR_base64

# --- Cifrado en reposo (AES-256-GCM). Generar 32 bytes: openssl rand -hex 32. Va en Secret Manager ---
APP_ENCRYPTION_KEY=

# --- Google OAuth (login con Google) ---
GOOGLE_CLIENT_ID=

# --- Pagos (Ola 3) ---
PAYMENT_PROVIDER=pagalo
PAGALO_API_URL=
PAGALO_API_KEY=CAMBIAR
PAGALO_WEBHOOK_SECRET=CAMBIAR

# --- CORS (dominios reales de prod) ---
CORS_ORIGINS=https://pasaeventos.com,https://www.pasaeventos.com
