# =====================================================================
# Pasa Eventos — variables de entorno (ejemplo)
# Copia a .env para desarrollo local. En prod usar GCP Secret Manager.
# Filosofía 12-factor: todo por env; el mismo binario corre local y en prod.
# =====================================================================

# --- General ---
NODE_ENV=development
PORT=8080
APP_NAME=PasaEventos
TZ=America/Guatemala

# --- Base de datos (PostgreSQL / Prisma) ---
# Local Docker: host = pasaeventos_db
DATABASE_URL=postgresql://pasaeventos:pasaeventos@pasaeventos_db:5432/pasaeventos?schema=public
# Prod (Cloud SQL): postgresql://USER:PASS@HOST:5432/DB?schema=public&sslmode=require

# --- Redis (cache / locks de asiento / rate-limit / colas BullMQ) ---
REDIS_URL=redis://pasaeventos_redis:6379
# Prod (Memorystore): rediss://:PASSWORD@HOST:6379

# --- RabbitMQ (bus de validación masiva) ---
AMQP_URL=amqp://pasaeventos:pasaeventos@pasaeventos_rabbitmq:5672
# Prod (CloudAMQP): amqps://USER:PASS@HOST/vhost

# --- Almacenamiento de objetos ---
# Local: S3 emulado por LocalStack. Prod: GCS.
STORAGE_PROVIDER=s3
S3_ENDPOINT=http://pasaeventos_localstack:4566
S3_REGION=us-east-1
S3_BUCKET=pasaeventos-local
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
S3_FORCE_PATH_STYLE=true
# Prod (GCS): STORAGE_PROVIDER=gcs
# GCLOUD_PROJECT_ID=
# GCS_BUCKET=
# GCS_SERVICE_ACCOUNT_JSON=  (contenido del JSON o via Secret Manager)

# --- Correo (MailHog local; SMTP/SES/SendGrid en prod) ---
MAIL_HOST=pasaeventos_mailhog
MAIL_PORT=1025
MAIL_USER=
MAIL_PASS=
MAIL_SECURE=false
MAIL_FROM=no-reply@pasaeventos.com

# --- Seguridad / Auth (se usa desde la Ola 1) ---
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_REFRESH_TTL=1209600

# --- Firma de boletos Ed25519 (se usa desde la Ola 4) ---
# TICKET_SIGNING_PRIVATE_KEY=  (base64, se genera en su ola)
# TICKET_SIGNING_PUBLIC_KEY=

# --- Google OAuth (opcional; login con Google. Vacío = deshabilitado) ---
GOOGLE_CLIENT_ID=

# --- Pasarela de pago (Ola 3) ---
PAYMENT_PROVIDER=simulator
# PAGALO_API_KEY=
# PAGALO_API_URL=
# PAGALO_WEBHOOK_SECRET=

# --- CORS ---
CORS_ORIGINS=http://localhost:4200,http://localhost:4201
