# =====================================================================
# Pasa Eventos — variables de entorno (ejemplo)
# Copia a .env para desarrollo local. En prod usar GCP Secret Manager.
# Filosofía 12-factor: todo por env; el mismo binario corre local y en prod.
# =====================================================================

# --- General ---
NODE_ENV=development
PORT=8080
APP_NAME=Boletiva
TZ=America/Guatemala

# --- Base de datos (PostgreSQL / Prisma) ---
# Local Docker: host = pasaeventos_db
DATABASE_URL=postgresql://pasaeventos:pasaeventos@pasaeventos_db:5432/pasaeventos?schema=public
# Prod (Cloud SQL): postgresql://USER:PASS@HOST:5432/DB?schema=public&sslmode=require

# --- Redis (cache / locks de asiento / rate-limit / colas BullMQ) ---
REDIS_URL=redis://pasaeventos_redis:6379
# Prod (Memorystore): rediss://:PASSWORD@HOST:6379

# --- RabbitMQ (bus de validación masiva) ---
AMQP_URL=amqp://pasaeventos:pasaeventos@pasaeventos_rabbitmq:5672
# Prod (CloudAMQP): amqps://USER:PASS@HOST/vhost

# --- Almacenamiento de objetos ---
# Local: S3 emulado por LocalStack. Prod: GCS.
STORAGE_PROVIDER=s3
S3_ENDPOINT=http://pasaeventos_localstack:4566
# Endpoint público para URLs firmadas de descarga (alcanzable desde el navegador).
# Dev: LocalStack mapeado al host 45660. Prod (GCS con endpoint público): vacío.
S3_PUBLIC_ENDPOINT=http://localhost:45660
S3_REGION=us-east-1
S3_BUCKET=pasaeventos-local
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
S3_FORCE_PATH_STYLE=true
# Prod (GCS): STORAGE_PROVIDER=gcs
# GCLOUD_PROJECT_ID=
# GCS_BUCKET=
# GCS_SERVICE_ACCOUNT_JSON=  (contenido del JSON o via Secret Manager)

# --- Correo (MailHog local; SMTP/SES/SendGrid en prod) ---
MAIL_HOST=pasaeventos_mailhog
MAIL_PORT=1025
MAIL_USER=
MAIL_PASS=
MAIL_SECURE=false
MAIL_FROM=no-reply@pasaeventos.com

# --- Seguridad / Auth (se usa desde la Ola 1) ---
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_REFRESH_TTL=1209600

# --- Firma de boletos Ed25519 (Ola 4). Seed de 32 bytes en hex (64 chars); la
# llave se deriva del seed. En prod: Secret Manager, rotable vía KEY_ID ---
TICKET_SIGNING_SEED=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff
TICKET_SIGNING_KEY_ID=dev-ed25519-1
# SafeTix (Ola 6.5): TTL del token de PUERTA (corto/fresco) y del manifiesto firmado
# (caduca offline; lleva secretos TOTP en claro), en segundos.
SAFETIX_GATE_TOKEN_TTL=1800
SAFETIX_MANIFEST_TTL=21600

# --- Colas (BullMQ, Ola 4) e ingest de validación (RabbitMQ, Ola 6) ---
# Sin definir → async (BullMQ sobre Redis / RabbitMQ). En test se fuerzan inline.
# QUEUE_INLINE=false
# RABBIT_INLINE=false

# --- Pases de wallet (Ola 4). 'stub' = sandbox sin certificados de terceros ---
WALLET_PROVIDER=stub

# --- Privacidad/retención (Ola 6). Job de anonimización (apagado por defecto) ---
RETENTION_ENABLED=false
RETENTION_DAYS=365

# --- Cifrado en reposo (AES-256-GCM). 32 bytes en hex (64 chars). Prod: Secret Manager ---
APP_ENCRYPTION_KEY=9f86d081884c7d659a2feaa0c55ad015a3bf4f1b2b0b822cd15d6c15b0f00a08

# --- Google OAuth (opcional; login con Google. Disponible = clientId + clientSecret) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Pasarela de pago (Ola 3) ---
PAYMENT_PROVIDER=simulator
PAYMENT_WEBHOOK_SECRET=dev-webhook-secret-change-me
# Simulador (dev/staging): auto-confirma el pago tras un jitter aleatorio para
# ejercitar el estado `pending` en el frontend. OFF por defecto y SIEMPRE en test.
# PAYMENT_SIMULATOR_AUTO_CONFIRM=true
# PAYMENT_SIMULATOR_JITTER_MIN_MS=1000
# PAYMENT_SIMULATOR_JITTER_MAX_MS=5000

# =====================================================================
# INTEGRACIONES EXTERNAS (configurables por env)
# Regla: si las credenciales están VACÍAS, el servicio queda NO DISPONIBLE
# (se ignora). Si se intenta usar un servicio no configurado, el backend
# responde 503 "servicio no disponible". Tutorial de credenciales + sandbox:
# docs/INTEGRACIONES-CREDENCIALES.md
# =====================================================================

# --- Recurrente (pasarela principal). Env-only por ahora; vacío = no disponible ---
RECURRENTE_API_KEY=
RECURRENTE_API_SECRET=
RECURRENTE_WEBHOOK_SECRET=
RECURRENTE_BASE_URL=https://app.recurrente.com/api

# --- Pagalo (pasarela alternativa/failover). Value-ready (pagalocard).
# Endpoint: POST https://{DOMINIO}/api/v1/integracion/{CREDENCIAL}. `credencial`,
# `dominio` y `estado` los da Pagalo (sandbox: sandbox.pagalocard.com); las llaves de
# empresa (key_public/key_secret/idenEmpresa) desde GCP Secret Manager. Vacío = no disponible.
PAGALO_CREDENCIAL=
PAGALO_DOMINIO=sandbox.pagalocard.com
PAGALO_ESTADO=sandbox
PAGALO_KEY_PUBLIC=
PAGALO_KEY_SECRET=
PAGALO_IDEN_EMPRESA=
PAGALO_WEBHOOK_SECRET=

# --- FEL (facturación electrónica SAT vía certificador). Env-only; vacío = no disponible ---
# certifier: infile | digifact | guatefacturas | ...
FEL_CERTIFIER=
FEL_API_USER=
FEL_API_KEY=
FEL_REQUESTOR_NIT=
FEL_BASE_URL=

# --- Apple Wallet (.pkpass). Env-only (requiere Apple Developer); vacío = no disponible ---
APPLE_WALLET_PASS_TYPE_ID=
APPLE_WALLET_TEAM_ID=
APPLE_WALLET_CERT_P12_BASE64=
APPLE_WALLET_CERT_PASSWORD=
APPLE_WALLET_WWDR_BASE64=

# --- Google Wallet. Value-ready; vacío = no disponible ---
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SERVICE_ACCOUNT_JSON=

# --- reCAPTCHA (anti-abuso). Value-ready. Sin SECRET_KEY o con DISABLED=true la
# verificación se OMITE (NO bloquea pruebas). En prod: definir SECRET_KEY y DISABLED=false.
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
# En test se desactiva automáticamente; en dev déjalo true para no bloquear.
RECAPTCHA_DISABLED=true

# --- GCP (deploy / Secret Manager / Google Wallet). region para las GitHub Actions ---
# GCLOUD_PROJECT_ID ya se define arriba (bloque de almacenamiento GCS).
GCP_REGION=us-central1

# --- CORS ---
CORS_ORIGINS=http://localhost:4200,http://localhost:4201

# --- Observabilidad (OpenTelemetry) ---
# Desactivado por defecto. Enciéndelo con OTEL_ENABLED=true (o definiendo el
# endpoint OTLP). Con el stack local, Jaeger expone OTLP/HTTP en el contenedor.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=pasaeventos-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://pasaeventos_jaeger:4318
