// Prisma schema — Pasa Eventos
// Fuente de verdad: PostgreSQL. Ver docs/ARQUITECTURA.md.
// Ola 0: settings. Ola 1: identidad (users/auth/rbac) + catálogo
// (categories/events/media) + venues (localities/seat_maps/seats).
// El pricing, órdenes, pagos, boletos, transferencias y ledger llegan en 2+.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  admin
  promoter
  promoter_staff
  gate_operator
  buyer
}

enum UserStatus {
  active
  inactive
  pending
}

enum EventStatus {
  draft
  published
  suspended // despublicado para reconfigurarse (cambio de salón/plantilla); re-publicable
  cancelled
  finished
}

enum LocalityKind {
  seated // con mapa de asientos
  general // admisión general (aforo)
}

enum SeatStatus {
  available
  held
  sold
  blocked
}

enum MediaKind {
  cover
  gallery
}

enum TwoFactorMethod {
  email
  totp
}

/// Propósito de un código/enlace enviado por correo.
enum ChallengePurpose {
  email_verify // verificar el correo
  passwordless // inicio de sesión sin contraseña (magic link + código)
  twofa_email // segundo factor por correo
  gateway_unlock // desbloqueo por OTP para agregar una pasarela (acción sensible, admin)
  event_edit_unlock // desbloqueo por OTP para que un ADMIN edite un evento ajeno (token 5 min)
}

/// Tipo/preset de una plantilla de disposición de asientos (v3.5). Los cuatro
/// primeros replican las plantillas built-in del editor; `custom` = creada por admin.
enum SeatTemplateKind {
  rows // filas rectas
  theater // filas curvadas hacia el escenario
  stadium // gradas en los cuatro lados de la cancha
  tables // mesas redondas
  grid // cuadrícula genérica
  curve // línea/arco curvo
  line // línea recta
  custom // definida a mano
}

/// Estado de publicación de contenido gestionable por admin (salones, plantillas
/// de asientos, v3.7): `draft` = solo lo ve el admin en su consola; `published` =
/// visible para el promotor (selector de salón / desplegable de plantillas).
enum ContentStatus {
  draft
  published
}

/// Estado de un intento de pago.
enum PaymentStatus {
  pending // creado; esperando confirmación del webhook
  succeeded // confirmado (fulfillment hecho)
  failed // rechazado por la pasarela
  refunded // reembolsado tras haber sido exitoso
}

/// Método de pago de un intento.
enum PaymentMethod {
  gateway // 100% pasarela
  wallet // 100% saldo interno
  mixed // saldo interno + pasarela (Ola 3 · pago mixto)
}

/// Estado operativo de una pasarela de pago configurada.
enum GatewayStatus {
  active // disponible para cobrar
  inactive // deshabilitada (no se puede usar; solo si no está en uso)
  maintenance // en mantenimiento (compras cerradas temporalmente)
}

/// Tipo de cuenta contable del ledger (partida doble).
enum LedgerAccountType {
  user_wallet // saldo interno del usuario (pasivo de la plataforma con el usuario)
  promoter_payable // lo que la plataforma debe al promotor (neto por liquidar)
  platform_revenue // ingreso de la plataforma (comisiones)
  tax_payable // IVA por pagar al fisco
  gateway_clearing // dinero en tránsito por la pasarela (liquidación)
  gateway_fee // costo de la comisión de pasarela
  payment_holding // fondos de wallet reservados durante un pago mixto (en tránsito)
  platform_expense // gastos extra (fuera del precio del boleto) compartidos promotor↔plataforma
  payout_pending // retiro de wallet reservado, pendiente de pago externo (neto al usuario)
  payout_settled // retiros ya pagados externamente (acumulado)
}

/// Estado de una solicitud de retiro de saldo interno (Ola 6).
enum WithdrawalStatus {
  pending // solicitada; saldo reservado; espera aprobación del admin
  approved // aprobada por el admin; pendiente de pago externo
  paid // pagada (transferencia externa realizada)
  rejected // rechazada por el admin (se reintegra el saldo)
  cancelled // cancelada por el usuario (se reintegra el saldo)
}

/// Estado de un boleto emitido (Ola 4).
enum TicketStatus {
  valid // emitido y válido
  used // ya validado en puerta (check-in)
  transferred // transferido a otro dueño; re-emitido (Ola 5)
  revoked // invalidado (reembolso/contracargo)
}

/// Tipo de movimiento en la cadena de custodia de un boleto (Ola 5).
enum TicketEventType {
  issued // emisión inicial
  transferred // regalo interno a otro dueño (re-emisión)
  checked_in // validado en puerta
  revoked // invalidado (reembolso/contracargo)
}

/// Estado de una transferencia (regalo) de boleto (Ola 5).
enum TransferStatus {
  pending // iniciada por el remitente; espera que el destinatario canjee el código
  claimed // canjeada (boleto re-emitido al destinatario)
  cancelled // cancelada por el remitente
  expired // venció sin canjearse
}

/// Estado de autorización de un usuario como promotor (Ola 4). Cualquier usuario
/// puede solicitar; un admin autoriza antes de que pueda operar. El "modo pruebas"
/// (setting `promoters.require_approval` = false) auto-aprueba al solicitar.
enum PromoterStatus {
  none // no ha solicitado ser promotor
  pending // solicitó; espera autorización del admin
  approved // autorizado; puede crear/publicar eventos y cobrar
  rejected // solicitud rechazada
  suspended // autorización revocada por el admin
}

/// Estado de una invitación de promotor por token (Ola F4).
enum PromoterInvitationStatus {
  pending // enviada; el token sigue vigente
  accepted // el destinatario se registró y quedó auto-aprobado
  revoked // cancelada por quien invitó
  expired // venció sin usarse
}

/// Estado de una orden de compra.
enum OrderStatus {
  pending // creada; asientos ya reservados (sold) a la espera de pago
  paid // pagada y confirmada (fulfillment)
  cancelled // cancelada por el usuario o el sistema
  expired // venció la ventana de pago sin completarse
  refunded // reembolsada tras el pago
}

// ---------------------------------------------------------------------------
// Configuración del sistema (Ola 0)
// ---------------------------------------------------------------------------

/// Configuración clave/valor del sistema (editable por el admin).
model Setting {
  key         String   @id
  value       Json
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// ---------------------------------------------------------------------------
// Identidad y autenticación (Ola 1)
// ---------------------------------------------------------------------------

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  // Opcional: usuarios solo-Google o passwordless pueden no tener contraseña.
  passwordHash String?    @map("password_hash")
  firstName    String     @map("first_name")
  lastName     String?    @map("last_name")
  phone        String?
  avatarUrl    String?    @map("avatar_url")
  status       UserStatus @default(active)
  roles        Role[]     @default([buyer])

  // Preferencia de idioma del usuario (v3.7): 'es' | 'en'. Se persiste desde el
  // perfil y se aplica en el frontend por encima de la preferencia de localStorage.
  language     String     @default("es")

  // Preferencia de FRANJA de tema del usuario (rebranding Boletiva): 'dia' | 'noche'
  // | null (null = usa la franja por defecto de la plataforma). El tema concreto lo
  // resuelve la asignación admin franja→tema. Solo aplica si el admin permite el switch.
  themePref    String?    @map("theme_pref")

  // Verificación de correo (null = no verificado).
  emailVerifiedAt DateTime? @map("email_verified_at")

  // 2FA: obligatorio una vez el email está verificado. email por defecto; totp opcional.
  twoFactorMethod   TwoFactorMethod @default(email) @map("two_factor_method")
  totpSecret        String?         @map("totp_secret")
  totpPendingSecret String?         @map("totp_pending_secret")

  // % de gastos EXTRA que asume este promotor (null = usa el default global).
  // Los gastos fuera del precio del boleto (p.ej. pasar boleto a wallet) se
  // reparten promotor↔plataforma; la parte del promotor se descuenta de su neto.
  costSharePct Decimal? @map("cost_share_pct") @db.Decimal(6, 5)

  // Autorización como promotor (Ola 4). Un usuario puede solicitar ser promotor;
  // un admin lo aprueba antes de que pueda operar (salvo en modo pruebas).
  promoterStatus    PromoterStatus @default(none) @map("promoter_status")
  promoterAppliedAt DateTime?      @map("promoter_applied_at")
  promoterDecidedAt DateTime?      @map("promoter_decided_at")
  promoterNote      String?        @map("promoter_note") // motivo de rechazo/suspensión
  // Nota interna del admin sobre el promotor (v3.8). Persistente e independiente
  // de `promoterNote` (que es el motivo de la última decisión y se limpia al
  // aprobar). Solo la ve/edita el admin en la consola; no se muestra al promotor.
  promoterInternalNote String? @map("promoter_internal_note")

  // Usuario de PRUEBA (v3.2): promotores invitados marcados como test no pueden
  // usar pasarelas reales (anclados a Sandbox) para no contaminar métricas de prod.
  isTestUser Boolean @default(false) @map("is_test_user")

  // Privacidad/retención (Ola 6): sello de anonimización (seudonimización de PII
  // preservando el ledger). null = datos personales intactos.
  anonymizedAt DateTime? @map("anonymized_at")

  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  events        Event[]            @relation("EventPromoter")
  // Eventos creados por este usuario (admin) a nombre de otro promotor (v3.8).
  eventsCreatedAsAdmin Event[]     @relation("EventCreatedByAdmin")
  refreshTokens RefreshToken[]
  recoveries    PasswordRecovery[]
  categories    Category[]
  challenges    AuthChallenge[]
  devices       Device[]
  oauthAccounts OAuthAccount[]
  orders        Order[]
  tickets       Ticket[]           @relation("TicketOwner")
  withdrawals   WalletWithdrawal[]
  gateAssignments GateAssignment[] @relation("GateOperator")
  promoterInvitations PromoterInvitation[] @relation("InvitedBy")
  savedCards SavedCard[]

  @@index([status])
  @@map("users")
}

/// Tarjetas guardadas (métodos de pago) tokenizadas (PCI-DSS). NUNCA se guarda el
/// PAN: la pasarela tokeniza en sus servidores y aquí solo persistimos el TOKEN
/// opaco reutilizable + la marca y los últimos 4 dígitos (no sensibles) para mostrar.
model SavedCard {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  brand     String // visa, mastercard, amex, ...
  last4     String   @db.VarChar(4)
  /// Token opaco devuelto por el tokenizador (referencia, no la tarjeta).
  token     String
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("saved_cards")
}

/// Refresh tokens con rotación y detección de reuso (por "family").
model RefreshToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  tokenHash    String    @unique @map("token_hash")
  family       String    @db.Uuid
  userAgent    String?   @map("user_agent")
  ip           String?
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  replacedById String?   @map("replaced_by_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([family])
  @@map("refresh_tokens")
}

model PasswordRecovery {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_recoveries")
}

/// Códigos OTP (6 dígitos) + enlace mágico, unificados por propósito.
/// Se guardan hasheados; nunca en claro.
model AuthChallenge {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  purpose   ChallengePurpose
  codeHash  String           @map("code_hash") // sha256 del código de 6 dígitos
  tokenHash String?          @unique @map("token_hash") // sha256 del token del magic link
  attempts  Int              @default(0)
  expiresAt DateTime         @map("expires_at")
  consumedAt DateTime?       @map("consumed_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@map("auth_challenges")
}

/// Dispositivos conocidos por usuario. `trustedAt` != null => pasó 2FA y no se
/// vuelve a exigir 2FA en ese dispositivo.
model Device {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  deviceHash String    @map("device_hash") // sha256 del device id del cliente
  userAgent  String?   @map("user_agent")
  ip         String?
  trustedAt  DateTime? @map("trusted_at")
  lastSeenAt DateTime  @default(now()) @map("last_seen_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceHash])
  @@index([userId])
  @@map("devices")
}

/// Cuentas de proveedores OAuth (Google, etc.) vinculadas a un usuario.
model OAuthAccount {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  provider          String // 'google'
  providerAccountId String   @map("provider_account_id")
  createdAt         DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

// ---------------------------------------------------------------------------
// Catálogo (Ola 1)
// ---------------------------------------------------------------------------

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  active      Boolean  @default(true)
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)
  events    Event[]

  @@index([active])
  @@map("categories")
}

model Event {
  id          String      @id @default(uuid()) @db.Uuid
  promoterId  String      @map("promoter_id") @db.Uuid
  categoryId  String?     @map("category_id") @db.Uuid
  name        String
  slug        String      @unique
  description String?
  address     String?
  lat         Float?
  lng         Float?
  startsAt    DateTime    @map("starts_at")
  endsAt      DateTime    @map("ends_at")
  status      EventStatus @default(draft)

  // Pagos dinámicos (Ola 3.5): pasarela elegida por el promotor (null = hereda la
  // default de plataforma). `frozenGatewayId` congela la pasarela usada para el
  // precio al recibir la primera compra (los precios ya no cambian). `ivaOnNet`:
  // si el promotor ya pagó IVA del boleto → false (IVA solo sobre la comisión de
  // plataforma). Referencias sin FK para permitir migrar al anular una pasarela.
  gatewayId       String?  @map("gateway_id") @db.Uuid
  frozenGatewayId String?  @map("frozen_gateway_id") @db.Uuid
  ivaOnNet        Boolean  @default(true) @map("iva_on_net")

  // Auditoría (v3.8): admin que creó el evento A NOMBRE de un promotor. null = lo
  // creó el propio promotor. El evento SIEMPRE pertenece al promotor (`promoterId`);
  // este campo solo deja rastro de quién lo originó desde la consola admin.
  createdByAdminId String? @map("created_by_admin_id") @db.Uuid

  // Salón/venue reutilizable (v3.5). Opcional: el promotor puede elegir un salón
  // pre-registrado (con dirección/coordenadas y layout de asientos) o escribir la
  // dirección a mano. Al asignarlo se pueden prefijar address/lat/lng si van vacíos.
  hallId String? @map("hall_id") @db.Uuid

  // Cuotas (Ola 6.5): si el promotor ABSORBE el recargo por pago en cuotas
  // (descontándolo de su neto en el ledger) en lugar de pasárselo al comprador.
  // false (default) = el recargo lo paga el comprador (gross-up mayor).
  absorbInstallmentCost Boolean @default(false) @map("absorb_installment_cost")

  // Máximo de transferencias (regalo) por boleto (Ola 5). null = usa el default
  // global (setting `transfer.max_per_ticket_default`).
  maxTransfers Int? @map("max_transfers")

  // Destacado editable (slider "hero" del inicio). null = no promocionado; un
  // entero define el ORDEN de prioridad (menor = primero). Lo edita admin/promotor.
  promotedPriority Int? @map("promoted_priority")

  // v3.10: sello de "cierre de caja" — cuándo un ADMIN finalizó el evento y
  // transfirió el saldo (neto acumulado) al wallet del promotor. Idempotencia:
  // con esto puesto, la transferencia no se repite.
  cashTransferredAt DateTime? @map("cash_transferred_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  promoter   User        @relation("EventPromoter", fields: [promoterId], references: [id])
  createdByAdmin User?   @relation("EventCreatedByAdmin", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  category   Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  hall       Hall?       @relation(fields: [hallId], references: [id], onDelete: SetNull)
  gateAssignments GateAssignment[]
  localities Locality[]
  media      EventMedia[]
  seatMaps   SeatMap[]
  orders     Order[]
  tickets    Ticket[]

  @@index([promoterId])
  @@index([status])
  @@index([startsAt])
  @@map("events")
}

model EventMedia {
  id        String    @id @default(uuid()) @db.Uuid
  eventId   String    @map("event_id") @db.Uuid
  key       String // clave del objeto en el bucket
  kind      MediaKind @default(gallery)
  position  Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_media")
}

// ---------------------------------------------------------------------------
// Venues: localidades, mapas de asiento (versionados) y asientos (Ola 1)
// ---------------------------------------------------------------------------

model Locality {
  id        String       @id @default(uuid()) @db.Uuid
  eventId   String       @map("event_id") @db.Uuid
  name      String
  slug      String
  kind      LocalityKind @default(general)
  capacity  Int          @default(0)
  /// Ganancia neta deseada por el promotor (input). El precio de venta se
  /// calcula en la Ola 2 (PricingEngine); aquí solo se captura el input.
  desiredNet Decimal?    @map("desired_net") @db.Decimal(12, 2)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  seats      Seat[]
  orderItems OrderItem[]
  tickets    Ticket[]

  @@unique([eventId, slug])
  @@index([eventId])
  @@map("localities")
}

/// Mapa de asientos versionado (inmutable por versión). El layout SVG/geometría
/// se guarda como jsonb; los asientos individuales viven en `seats`.
model SeatMap {
  id         String   @id @default(uuid()) @db.Uuid
  eventId    String   @map("event_id") @db.Uuid
  version    Int      @default(1)
  name       String?
  width      Int      @default(1000)
  height     Int      @default(800)
  background Json?
  layout     Json     @default("{}")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, version])
  @@index([eventId])
  @@map("seat_maps")
}

model Seat {
  id         String     @id @default(uuid()) @db.Uuid
  localityId String     @map("locality_id") @db.Uuid
  section    String?
  row        String?
  label      String
  x          Float?
  y          Float?
  status     SeatStatus @default(available)
  createdAt  DateTime   @default(now()) @map("created_at")

  locality   Locality    @relation(fields: [localityId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  tickets    Ticket[]

  @@unique([localityId, label])
  @@index([localityId])
  @@index([status])
  @@map("seats")
}

// ---------------------------------------------------------------------------
// Precios: tabla de comisiones versionada (Ola 2)
// ---------------------------------------------------------------------------

/// Configuración de comisiones VERSIONADA e inmutable. El admin no edita en
/// sitio: crea una versión nueva y la activa (solo una activa a la vez, vía
/// índice único parcial `fee_schedules_one_active`). Cada orden guarda la
/// versión usada para reproducir su cotización. Porcentajes en [0, 1).
model FeeSchedule {
  id             String   @id @default(uuid()) @db.Uuid
  version        Int      @unique
  label          String?
  platformFeePct Decimal  @map("platform_fee_pct") @db.Decimal(6, 5)
  gatewayFeePct  Decimal  @map("gateway_fee_pct") @db.Decimal(6, 5)
  ivaPct         Decimal  @map("iva_pct") @db.Decimal(6, 5)
  fixedFees      Decimal  @default(0) @map("fixed_fees") @db.Decimal(12, 2)
  active         Boolean  @default(false)
  createdById    String?  @map("created_by_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  orders Order[]

  @@map("fee_schedules")
}

// ---------------------------------------------------------------------------
// Órdenes (Ola 2 · commit anti-doble-venta / Ola 3 · pagos)
// ---------------------------------------------------------------------------

/// Orden de compra. Al crearse (commit), los asientos pasan a `sold` dentro de
/// una transacción con SELECT ... FOR UPDATE (0 doble-venta). Los totales son un
/// snapshot inmutable del PricingEngine (server-authoritative). Dinero en Decimal.
model Order {
  id       String      @id @default(uuid()) @db.Uuid
  buyerId  String      @map("buyer_id") @db.Uuid
  eventId  String      @map("event_id") @db.Uuid
  status   OrderStatus @default(pending)
  currency String      @default("GTQ")

  // Snapshot de totales (suma de los ítems). Nunca `number` para dinero.
  net         Decimal @db.Decimal(12, 2)
  fixedFees   Decimal @default(0) @db.Decimal(12, 2)
  platformFee Decimal @db.Decimal(12, 2)
  taxableBase Decimal @db.Decimal(12, 2)
  iva         Decimal @db.Decimal(12, 2)
  gatewayFee  Decimal @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  // Versión de comisiones usada (reproduce la cotización de forma auditable).
  feeScheduleId      String? @map("fee_schedule_id") @db.Uuid
  feeScheduleVersion Int?    @map("fee_schedule_version")
  feeGatewayId       String? @map("fee_gateway_id") @db.Uuid // pasarela usada en la cotización

  // Facturación electrónica (FEL, Guatemala). NIT 'CF' = consumidor final.
  // Los campos de autorización se llenan al certificar la factura (Ola 3+).
  billingNit     String    @default("CF") @map("billing_nit")
  billingName    String?   @map("billing_name")
  billingAddress String?   @map("billing_address")
  felUuid        String?   @map("fel_uuid")
  felSerie       String?   @map("fel_serie")
  felNumero      String?   @map("fel_numero")
  felCertifiedAt DateTime? @map("fel_certified_at")

  expiresAt   DateTime? @map("expires_at")
  paidAt      DateTime? @map("paid_at")
  cancelledAt DateTime? @map("cancelled_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  buyer       User         @relation(fields: [buyerId], references: [id])
  event       Event        @relation(fields: [eventId], references: [id])
  feeSchedule FeeSchedule? @relation(fields: [feeScheduleId], references: [id])
  items       OrderItem[]
  payments    Payment[]
  tickets     Ticket[]

  @@index([buyerId])
  @@index([eventId])
  @@index([status])
  @@map("orders")
}

/// Línea de una orden = un asiento (o cupo general). Guarda el PriceQuote
/// completo del PricingEngine como snapshot inmutable (jsonb). `active` = false
/// al cancelar/reembolsar: libera el asiento y el índice único parcial.
model OrderItem {
  id         String  @id @default(uuid()) @db.Uuid
  orderId    String  @map("order_id") @db.Uuid
  localityId String  @map("locality_id") @db.Uuid
  seatId     String? @map("seat_id") @db.Uuid // null = admisión general (aforo)
  label      String?

  // Snapshot de precio por ítem.
  net       Decimal @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)
  quote     Json // PriceQuote íntegro (incluye hash anti-manipulación)
  quoteHash String  @map("quote_hash")

  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  locality Locality @relation(fields: [localityId], references: [id])
  seat     Seat?    @relation(fields: [seatId], references: [id])
  ticket   Ticket?

  @@index([orderId])
  @@index([seatId])
  @@map("order_items")
}

// ---------------------------------------------------------------------------
// Pasarelas de pago configurables (Ola 3.5 · pagos dinámicos)
// ---------------------------------------------------------------------------

/// Pasarela de pago configurable. Su comisión (`feePct`) entra al gross-up del
/// precio (dinámico por método). `credentialsRef` es una REFERENCIA al secreto
/// (nombre en Secret Manager/env), nunca el secreto en claro. Solo una puede ser
/// la default de plataforma (índice parcial `payment_gateways_one_default`).
model PaymentGateway {
  id               String        @id @default(uuid()) @db.Uuid
  name             String        @unique
  provider         String // 'simulator' | 'recurrente' | 'pagalo' | 'stripe' | ...
  feePct           Decimal       @map("fee_pct") @db.Decimal(6, 5)
  /// Comisión efectiva de pasarela POR CANTIDAD DE CUOTAS (Visacuotas/Mastercuotas).
  /// Mapa { "3": 0.08, "6": 0.09, "12": 0.10, "18": 0.14 } = tasa de la pasarela
  /// para N cuotas. null / ausente / clave "1" → pago único usa `feePct`. El costo
  /// extra lo absorbe la plataforma (o el promotor si el evento lo marca); el
  /// comprador paga siempre el precio de 1 pago (recargo directo prohibido en GT).
  installmentRates Json?         @map("installment_rates")
  /// Cargo FIJO por transacción en cuotas (GTQ, p.ej. Q2 de Recurrente). Se suma
  /// al costo que absorbe la plataforma/promotor. null/0 = sin fijo.
  installmentFixedFee Decimal?   @map("installment_fixed_fee") @db.Decimal(12, 2)
  /// Ola 6.6: cargo FIJO por transacción que aplica a TODO cobro (pago único y
  /// cuotas). Se grossea como el %; el comprador lo paga por boleto y al combinar
  /// N boletos en 1 transacción la plataforma captura (N-1)·fijo. Pagalo = 0.
  transactionFixedFee Decimal   @default(0) @map("transaction_fixed_fee") @db.Decimal(12, 2)
  /// Ola 6.6: % MÍNIMO de cost-share del promotor para poder USAR esta pasarela
  /// (0 = disponible para todos; p.ej. PayPal 0.50). La pasarela default del
  /// sistema ignora este umbral (siempre vendible).
  minCostSharePct  Decimal       @default(0) @map("min_cost_share_pct") @db.Decimal(6, 5)
  credentialsRef   String?       @map("credentials_ref")
  status           GatewayStatus @default(active)
  isPlatformDefault Boolean      @default(false) @map("is_platform_default")
  sandbox          Boolean       @default(false)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  @@index([status])
  @@map("payment_gateways")
}

// ---------------------------------------------------------------------------
// Pagos: puerto PaymentProvider + webhooks (Ola 3)
// ---------------------------------------------------------------------------

/// Intento de pago de una orden. El fulfillment se dispara por WEBHOOK de la
/// pasarela (webhook-first): la orden queda pending hasta payment.succeeded.
model Payment {
  id           String        @id @default(uuid()) @db.Uuid
  orderId      String        @map("order_id") @db.Uuid
  provider     String // 'simulator' | 'pagalo' | ...
  providerRef  String        @unique @map("provider_ref") // referencia en la pasarela
  method       PaymentMethod @default(gateway)
  status       PaymentStatus @default(pending)
  // Monto cobrado por la pasarela y monto cubierto con saldo interno (pago mixto).
  amount       Decimal       @db.Decimal(12, 2)
  walletAmount Decimal       @default(0) @map("wallet_amount") @db.Decimal(12, 2)
  currency     String        @default("GTQ")
  failureReason String?      @map("failure_reason")
  succeededAt  DateTime?     @map("succeeded_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@map("payments")
}

/// Evento de webhook recibido (idempotencia + auditoría). El par (provider,
/// eventId) es único: reintentos/replays no se reprocesan.
model WebhookEvent {
  id          String    @id @default(uuid()) @db.Uuid
  provider    String
  eventId     String    @map("event_id") // id del evento en la pasarela
  type        String
  providerRef String?   @map("provider_ref")
  payload     Json
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([provider, eventId])
  @@map("webhook_events")
}

// ---------------------------------------------------------------------------
// Ledger contable de partida doble con hash-chain (Ola 3)
// ---------------------------------------------------------------------------

/// Cuenta contable. El saldo (`balance`) se cachea y se actualiza dentro de la
/// misma transacción que asienta los movimientos (derivable de sus entries).
/// Cuentas de usuario/promotor: `ownerId` = user.id; cuentas de sistema: null.
model LedgerAccount {
  id        String            @id @default(uuid()) @db.Uuid
  type      LedgerAccountType
  ownerId   String?           @map("owner_id") @db.Uuid
  currency  String            @default("GTQ")
  balance   Decimal           @default(0) @db.Decimal(14, 2)
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  entries LedgerEntry[]

  @@unique([type, ownerId, currency])
  @@index([ownerId])
  @@map("ledger_accounts")
}

/// Transacción contable: agrupa ≥2 asientos que SUMAN 0 (partida doble).
/// Encadenada por hash (blockchain): hash = sha256(prevHash + contenido canónico).
/// Append-only e inmutable; `seq` da el orden del chain.
model LedgerTransaction {
  id        String   @id @default(uuid()) @db.Uuid
  seq       BigInt    @unique @default(autoincrement())
  kind      String // 'order_payment' | 'wallet_topup' | 'payout' | 'refund' | 'chargeback'
  refType   String?  @map("ref_type") // p.ej. 'order'
  refId     String?  @map("ref_id") @db.Uuid
  prevHash  String   @map("prev_hash") // hash de la transacción anterior ('' en génesis)
  hash      String   @unique // sha256(prevHash + seq + kind + entries + createdAt)
  memo      String?
  createdAt DateTime @default(now()) @map("created_at")

  entries LedgerEntry[]

  @@index([refType, refId])
  @@map("ledger_transactions")
}

/// Asiento contable individual. `amount` firmado (Decimal): + acredita, - debita
/// el saldo de la cuenta. La suma de los asientos de una transacción es 0.
model LedgerEntry {
  id            String   @id @default(uuid()) @db.Uuid
  transactionId String   @map("transaction_id") @db.Uuid
  accountId     String   @map("account_id") @db.Uuid
  amount        Decimal  @db.Decimal(14, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  transaction LedgerTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  account     LedgerAccount     @relation(fields: [accountId], references: [id])

  @@index([transactionId])
  @@index([accountId])
  @@map("ledger_entries")
}

// ---------------------------------------------------------------------------
// Boletos: firma Ed25519 + QR rotativo (TOTP), emisión async (Ola 4)
// ---------------------------------------------------------------------------

/// Boleto emitido (uno por línea de orden). La emisión se ENCOLA (BullMQ) tras
/// asentar el pago en el ledger, para no bloquear el event loop ni el webhook.
/// La identidad inmutable va firmada con Ed25519 (anti-falsificación); un secreto
/// TOTP por boleto (cifrado en reposo) produce un QR ROTATIVO (un screenshot no
/// sirve). La validación offline dinámica + manifiesto se completa en la Ola 5.
model Ticket {
  id          String       @id @default(uuid()) @db.Uuid
  orderItemId String       @unique @map("order_item_id") @db.Uuid
  orderId     String       @map("order_id") @db.Uuid
  eventId     String       @map("event_id") @db.Uuid
  localityId  String       @map("locality_id") @db.Uuid
  seatId      String?      @map("seat_id") @db.Uuid
  ownerId     String       @map("owner_id") @db.Uuid // dueño actual (comprador)
  serial      String       @unique // id público legible (base del QR)
  status      TicketStatus @default(valid)

  // Criptografía del boleto.
  signature    String // firma Ed25519 (base64) sobre la identidad inmutable
  signingKeyId String @map("signing_key_id") // id de la llave usada (rotación)
  totpSecret   String @map("totp_secret") // secreto base32 CIFRADO (AES-256-GCM)

  // Media generada de forma asíncrona (claves en el bucket).
  qrKey        String?   @map("qr_key")
  pdfKey       String?   @map("pdf_key")
  mediaReadyAt DateTime? @map("media_ready_at")

  // Transferencias (regalo interno, Ola 5): nº de veces ya transferido.
  transferCount Int @default(0) @map("transfer_count")

  usedAt    DateTime? @map("used_at")
  revokedAt DateTime? @map("revoked_at")
  issuedAt  DateTime  @default(now()) @map("issued_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  order     Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem OrderItem            @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  event     Event                @relation(fields: [eventId], references: [id])
  owner     User                 @relation("TicketOwner", fields: [ownerId], references: [id])
  seat      Seat?                @relation(fields: [seatId], references: [id])
  locality  Locality             @relation(fields: [localityId], references: [id])
  custody   TicketCustodyEvent[]
  transfers TicketTransfer[]

  @@index([ownerId])
  @@index([eventId])
  @@index([orderId])
  @@index([status])
  @@map("tickets")
}

/// Cadena de custodia de un boleto (Ola 5): bitácora append-only encadenada por
/// hash (blockchain) de cada movimiento (emisión→transferencia→check-in→revocación).
/// Huella inborrable; `seq` da el orden dentro del boleto y `prevHash` enlaza.
model TicketCustodyEvent {
  id          String          @id @default(uuid()) @db.Uuid
  ticketId    String          @map("ticket_id") @db.Uuid
  seq         Int // orden dentro del boleto (1..n)
  type        TicketEventType
  fromOwnerId String?         @map("from_owner_id") @db.Uuid
  toOwnerId   String?         @map("to_owner_id") @db.Uuid
  actorId     String?         @map("actor_id") @db.Uuid // quién ejecutó el movimiento
  prevHash    String          @map("prev_hash") // hash del evento anterior del boleto ('' en génesis)
  hash        String          @unique // sha256(prevHash + ticketId + seq + type + from + to + createdAt)
  meta        Json?
  createdAt   DateTime        @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([ticketId, seq])
  @@index([ticketId])
  @@map("ticket_custody_events")
}

/// Transferencia (regalo interno) de un boleto (Ola 5). Handshake de doble
/// confirmación: el remitente inicia y recibe un código (guardado hasheado); el
/// destinatario verificado lo canjea. Solo puede haber UNA pendiente por boleto
/// (índice parcial `ticket_transfers_one_pending`).
model TicketTransfer {
  id          String         @id @default(uuid()) @db.Uuid
  ticketId    String         @map("ticket_id") @db.Uuid
  senderId    String         @map("sender_id") @db.Uuid
  recipientId String?        @map("recipient_id") @db.Uuid
  codeHash    String         @map("code_hash") // sha256 del código común
  status      TransferStatus @default(pending)
  expiresAt   DateTime       @map("expires_at")
  claimedAt   DateTime?      @map("claimed_at")
  createdAt   DateTime       @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([codeHash])
  @@map("ticket_transfers")
}

/// Conflicto de validación detectado al ingerir check-ins masivos (Ola 6): un
/// boleto que llegó a validarse en más de una puerta (doble entrada). Se registra
/// para revisión del organizador; no bloquea el ingest (idempotente).
model CheckinConflict {
  id          String   @id @default(uuid()) @db.Uuid
  ticketId    String   @map("ticket_id") @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  serial      String
  gateId      String?  @map("gate_id") // puerta que reintentó validar
  reason      String // 'already_used' | ...
  attemptedAt DateTime @map("attempted_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([eventId])
  @@index([ticketId])
  @@map("checkin_conflicts")
}

/// Solicitud de retiro de saldo interno (Ola 6). Flujo solicitud→aprobación→pago.
/// Al solicitar se RESERVA el saldo en el ledger (user_wallet→payout_pending +
/// comisión a la plataforma); rechazar/cancelar lo reintegra; pagar lo liquida.
/// La comisión del usuario es el doble que la del promotor.
model WalletWithdrawal {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  amount      Decimal          @db.Decimal(12, 2) // monto bruto a debitar del wallet
  feePct      Decimal          @map("fee_pct") @db.Decimal(6, 5)
  fee         Decimal          @db.Decimal(12, 2)
  net         Decimal          @db.Decimal(12, 2) // amount - fee (lo que recibe el usuario)
  currency    String           @default("GTQ")
  status      WithdrawalStatus @default(pending)
  note        String? // motivo de rechazo / referencia de pago
  decidedById String?          @map("decided_by_id") @db.Uuid // admin que decidió
  decidedAt   DateTime?        @map("decided_at")
  paidAt      DateTime?        @map("paid_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("wallet_withdrawals")
}

/// Bitácora de sincronización para validadores offline (Ola 5, modelo SafeTix).
/// Cada emisión/transferencia/check-in/revocación agrega una entrada; el
/// dispositivo de puerta hace pull incremental (`seq` global monótono) y aplica
/// el último estado por boleto. El secreto TOTP NO se guarda aquí (se sirve
/// descifrado al armar el manifiesto, sobre TLS y solo a operadores de puerta).
model TicketSyncEntry {
  seq       BigInt          @id @default(autoincrement())
  eventId   String          @map("event_id") @db.Uuid
  ticketId  String          @map("ticket_id") @db.Uuid
  reason    TicketEventType
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([eventId, seq])
  @@map("ticket_sync_entries")
}

/// Asignación de un operador de puerta a un evento (Ola 6.5, SafeTix). Un admin o
/// el promotor dueño la crea; acota qué eventos puede validar cada operador. Se
/// verifica (además del claim `gateEventId` del token de puerta corto) al pedir el
/// manifiesto → defensa en profundidad: revocar la asignación corta el acceso.
model GateAssignment {
  id          String   @id @default(uuid()) @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  operatorId  String   @map("operator_id") @db.Uuid
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  event    Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  operator User  @relation("GateOperator", fields: [operatorId], references: [id], onDelete: Cascade)

  @@unique([eventId, operatorId])
  @@index([operatorId])
  @@map("gate_assignments")
}

/// Invitación de promotor por token (Ola F4). Un admin o promotor aprobado invita
/// por correo; el destinatario abre la URL con el token, se registra con el email
/// precargado y queda AUTO-APROBADO como promotor (se salta la autorización). El
/// token se guarda hasheado (solo se muestra una vez en la URL).
model PromoterInvitation {
  id               String                   @id @default(uuid()) @db.Uuid
  email            String
  tokenHash        String                   @unique @map("token_hash")
  status           PromoterInvitationStatus @default(pending)
  /// Marca al invitado como usuario de PRUEBA: al aceptar, su User queda con
  /// isTestUser=true (anclado a Sandbox, no usa pasarelas reales).
  isTestUser       Boolean                  @default(false) @map("is_test_user")
  invitedById      String                   @map("invited_by_id") @db.Uuid
  acceptedByUserId String?                  @map("accepted_by_user_id") @db.Uuid
  expiresAt        DateTime                 @map("expires_at")
  acceptedAt       DateTime?                @map("accepted_at")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")

  invitedBy User @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([invitedById])
  @@map("promoter_invitations")
}

/// Historial APPEND-ONLY de transiciones de estado de un promotor (v3.2). El
/// estado actual sigue en User.promoterStatus; cada cambio (approve/reject/
/// suspend/reactivar) se audita aquí con quién lo hizo y el motivo. Nunca se edita.
model PromoterStatusEvent {
  id         String         @id @default(uuid()) @db.Uuid
  promoterId String         @map("promoter_id") @db.Uuid
  adminId    String?        @map("admin_id") @db.Uuid // quién ejecutó (null = sistema)
  statusFrom PromoterStatus @map("status_from")
  statusTo   PromoterStatus @map("status_to")
  reason     String?
  createdAt  DateTime       @default(now()) @map("created_at")

  @@index([promoterId])
  @@map("promoter_status_events")
}

// ---------------------------------------------------------------------------
// Salones y plantillas de asientos (v3.5)
// ---------------------------------------------------------------------------

/// Salón/venue reutilizable. Un admin lo gestiona; cualquier promotor lo elige al
/// crear un evento para prefijar dirección/coordenadas y, opcionalmente, arrancar
/// con un layout de asientos (`seatTemplateId`). No se materializan asientos aquí:
/// solo referencia la geometría base que el editor del evento puede aplicar.
model Hall {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  address        String?
  lat            Float?
  lng            Float?
  city           String?
  notes          String?
  seatTemplateId String?  @map("seat_template_id") @db.Uuid
  /// v3.7: draft (solo admin) | published (visible en el selector del promotor).
  status         ContentStatus @default(draft)
  /// v3.10: oculto del selector del promotor sin eliminarlo (reversible).
  hidden         Boolean  @default(false)
  /// v3.10: deshabilitado (prerequisito para poder ELIMINARlo). No sale al promotor.
  disabled       Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  seatTemplate SeatTemplate? @relation(fields: [seatTemplateId], references: [id], onDelete: SetNull)
  events       Event[]

  @@index([name])
  @@index([status])
  @@map("halls")
}

/// Plantilla de disposición de asientos (v3.5). Registra los presets del editor
/// (built-in) y las plantillas que el admin cree a mano. `layoutJson` guarda la
/// metadata de presentación (icono/hint) o la geometría; `params` los parámetros
/// de generación (filas, columnas, radio, etc.). Built-in = no borrable/editable.
model SeatTemplate {
  id         String           @id @default(uuid()) @db.Uuid
  name       String
  kind       SeatTemplateKind @default(custom)
  layoutJson Json             @default("{}") @map("layout_json")
  params     Json?
  isBuiltIn  Boolean          @default(false) @map("is_built_in")
  /// v3.7: draft (solo admin) | published (visible en el desplegable del editor).
  status     ContentStatus    @default(draft)
  /// v3.7: oculta del desplegable del promotor sin eliminarla (reversible).
  hidden     Boolean          @default(false)
  /// v3.7: deshabilitada (prerequisito para poder ELIMINARla). No sale al promotor.
  disabled   Boolean          @default(false)
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  halls Hall[]

  @@index([kind])
  @@index([status])
  @@map("seat_templates")
}

/// Bitácora de auditoría (v3.8, no-repudio). Registro APPEND-ONLY encadenado por
/// hash (misma técnica que el ledger/custody: `prevHash` + `hash=sha256(prevHash+
/// contenido)` + `seq` monótono) de acciones sensibles y de CADA click de
/// confirmación del frontend. Captura contexto server-side (IP y user-agent del
/// request, NO del body) para justificar "usted dio click en confirmar". El
/// `userId` se guarda como texto plano SIN FK: la anonimización de un usuario NO
/// debe borrar ni romper su rastro de auditoría (trazabilidad intacta).
model AuditEvent {
  id        String   @id @default(uuid()) @db.Uuid
  seq       BigInt   @default(autoincrement())
  userId    String?  @map("user_id")
  action    String
  resource  String?
  ip        String?
  userAgent String?  @map("user_agent")
  payload   Json?
  prevHash  String   @map("prev_hash")
  hash      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([createdAt, id])
  @@map("audit_events")
}
