// Prisma schema — Pasa Eventos
// Fuente de verdad: PostgreSQL. Ver docs/ARQUITECTURA.md.
// Ola 0: settings. Ola 1: identidad (users/auth/rbac) + catálogo
// (categories/events/media) + venues (localities/seat_maps/seats).
// El pricing, órdenes, pagos, boletos, transferencias y ledger llegan en 2+.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  admin
  promoter
  promoter_staff
  gate_operator
  buyer
}

enum UserStatus {
  active
  inactive
  pending
}

enum EventStatus {
  draft
  published
  cancelled
  finished
}

enum LocalityKind {
  seated // con mapa de asientos
  general // admisión general (aforo)
}

enum SeatStatus {
  available
  held
  sold
  blocked
}

enum MediaKind {
  cover
  gallery
}

enum TwoFactorMethod {
  email
  totp
}

/// Propósito de un código/enlace enviado por correo.
enum ChallengePurpose {
  email_verify // verificar el correo
  passwordless // inicio de sesión sin contraseña (magic link + código)
  twofa_email // segundo factor por correo
}

/// Tipo de cuenta contable del ledger (partida doble).
enum LedgerAccountType {
  user_wallet // saldo interno del usuario (pasivo de la plataforma con el usuario)
  promoter_payable // lo que la plataforma debe al promotor (neto por liquidar)
  platform_revenue // ingreso de la plataforma (comisiones)
  tax_payable // IVA por pagar al fisco
  gateway_clearing // dinero en tránsito por la pasarela (liquidación)
  gateway_fee // costo de la comisión de pasarela
}

/// Estado de una orden de compra.
enum OrderStatus {
  pending // creada; asientos ya reservados (sold) a la espera de pago
  paid // pagada y confirmada (fulfillment)
  cancelled // cancelada por el usuario o el sistema
  expired // venció la ventana de pago sin completarse
  refunded // reembolsada tras el pago
}

// ---------------------------------------------------------------------------
// Configuración del sistema (Ola 0)
// ---------------------------------------------------------------------------

/// Configuración clave/valor del sistema (editable por el admin).
model Setting {
  key         String   @id
  value       Json
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// ---------------------------------------------------------------------------
// Identidad y autenticación (Ola 1)
// ---------------------------------------------------------------------------

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  // Opcional: usuarios solo-Google o passwordless pueden no tener contraseña.
  passwordHash String?    @map("password_hash")
  firstName    String     @map("first_name")
  lastName     String?    @map("last_name")
  phone        String?
  avatarUrl    String?    @map("avatar_url")
  status       UserStatus @default(active)
  roles        Role[]     @default([buyer])

  // Verificación de correo (null = no verificado).
  emailVerifiedAt DateTime? @map("email_verified_at")

  // 2FA: obligatorio una vez el email está verificado. email por defecto; totp opcional.
  twoFactorMethod   TwoFactorMethod @default(email) @map("two_factor_method")
  totpSecret        String?         @map("totp_secret")
  totpPendingSecret String?         @map("totp_pending_secret")

  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  events        Event[]            @relation("EventPromoter")
  refreshTokens RefreshToken[]
  recoveries    PasswordRecovery[]
  categories    Category[]
  challenges    AuthChallenge[]
  devices       Device[]
  oauthAccounts OAuthAccount[]
  orders        Order[]

  @@index([status])
  @@map("users")
}

/// Refresh tokens con rotación y detección de reuso (por "family").
model RefreshToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  tokenHash    String    @unique @map("token_hash")
  family       String    @db.Uuid
  userAgent    String?   @map("user_agent")
  ip           String?
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  replacedById String?   @map("replaced_by_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([family])
  @@map("refresh_tokens")
}

model PasswordRecovery {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_recoveries")
}

/// Códigos OTP (6 dígitos) + enlace mágico, unificados por propósito.
/// Se guardan hasheados; nunca en claro.
model AuthChallenge {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  purpose   ChallengePurpose
  codeHash  String           @map("code_hash") // sha256 del código de 6 dígitos
  tokenHash String?          @unique @map("token_hash") // sha256 del token del magic link
  attempts  Int              @default(0)
  expiresAt DateTime         @map("expires_at")
  consumedAt DateTime?       @map("consumed_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@map("auth_challenges")
}

/// Dispositivos conocidos por usuario. `trustedAt` != null => pasó 2FA y no se
/// vuelve a exigir 2FA en ese dispositivo.
model Device {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  deviceHash String    @map("device_hash") // sha256 del device id del cliente
  userAgent  String?   @map("user_agent")
  ip         String?
  trustedAt  DateTime? @map("trusted_at")
  lastSeenAt DateTime  @default(now()) @map("last_seen_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceHash])
  @@index([userId])
  @@map("devices")
}

/// Cuentas de proveedores OAuth (Google, etc.) vinculadas a un usuario.
model OAuthAccount {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  provider          String // 'google'
  providerAccountId String   @map("provider_account_id")
  createdAt         DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

// ---------------------------------------------------------------------------
// Catálogo (Ola 1)
// ---------------------------------------------------------------------------

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  active      Boolean  @default(true)
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)
  events    Event[]

  @@index([active])
  @@map("categories")
}

model Event {
  id          String      @id @default(uuid()) @db.Uuid
  promoterId  String      @map("promoter_id") @db.Uuid
  categoryId  String?     @map("category_id") @db.Uuid
  name        String
  slug        String      @unique
  description String?
  address     String?
  lat         Float?
  lng         Float?
  startsAt    DateTime    @map("starts_at")
  endsAt      DateTime    @map("ends_at")
  status      EventStatus @default(draft)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  promoter   User        @relation("EventPromoter", fields: [promoterId], references: [id])
  category   Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  localities Locality[]
  media      EventMedia[]
  seatMaps   SeatMap[]
  orders     Order[]

  @@index([promoterId])
  @@index([status])
  @@index([startsAt])
  @@map("events")
}

model EventMedia {
  id        String    @id @default(uuid()) @db.Uuid
  eventId   String    @map("event_id") @db.Uuid
  key       String // clave del objeto en el bucket
  kind      MediaKind @default(gallery)
  position  Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_media")
}

// ---------------------------------------------------------------------------
// Venues: localidades, mapas de asiento (versionados) y asientos (Ola 1)
// ---------------------------------------------------------------------------

model Locality {
  id        String       @id @default(uuid()) @db.Uuid
  eventId   String       @map("event_id") @db.Uuid
  name      String
  slug      String
  kind      LocalityKind @default(general)
  capacity  Int          @default(0)
  /// Ganancia neta deseada por el promotor (input). El precio de venta se
  /// calcula en la Ola 2 (PricingEngine); aquí solo se captura el input.
  desiredNet Decimal?    @map("desired_net") @db.Decimal(12, 2)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  seats      Seat[]
  orderItems OrderItem[]

  @@unique([eventId, slug])
  @@index([eventId])
  @@map("localities")
}

/// Mapa de asientos versionado (inmutable por versión). El layout SVG/geometría
/// se guarda como jsonb; los asientos individuales viven en `seats`.
model SeatMap {
  id         String   @id @default(uuid()) @db.Uuid
  eventId    String   @map("event_id") @db.Uuid
  version    Int      @default(1)
  name       String?
  width      Int      @default(1000)
  height     Int      @default(800)
  background Json?
  layout     Json     @default("{}")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, version])
  @@index([eventId])
  @@map("seat_maps")
}

model Seat {
  id         String     @id @default(uuid()) @db.Uuid
  localityId String     @map("locality_id") @db.Uuid
  section    String?
  row        String?
  label      String
  x          Float?
  y          Float?
  status     SeatStatus @default(available)
  createdAt  DateTime   @default(now()) @map("created_at")

  locality   Locality    @relation(fields: [localityId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@unique([localityId, label])
  @@index([localityId])
  @@index([status])
  @@map("seats")
}

// ---------------------------------------------------------------------------
// Precios: tabla de comisiones versionada (Ola 2)
// ---------------------------------------------------------------------------

/// Configuración de comisiones VERSIONADA e inmutable. El admin no edita en
/// sitio: crea una versión nueva y la activa (solo una activa a la vez, vía
/// índice único parcial `fee_schedules_one_active`). Cada orden guarda la
/// versión usada para reproducir su cotización. Porcentajes en [0, 1).
model FeeSchedule {
  id             String   @id @default(uuid()) @db.Uuid
  version        Int      @unique
  label          String?
  platformFeePct Decimal  @map("platform_fee_pct") @db.Decimal(6, 5)
  gatewayFeePct  Decimal  @map("gateway_fee_pct") @db.Decimal(6, 5)
  ivaPct         Decimal  @map("iva_pct") @db.Decimal(6, 5)
  fixedFees      Decimal  @default(0) @map("fixed_fees") @db.Decimal(12, 2)
  active         Boolean  @default(false)
  createdById    String?  @map("created_by_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  orders Order[]

  @@map("fee_schedules")
}

// ---------------------------------------------------------------------------
// Órdenes (Ola 2 · commit anti-doble-venta / Ola 3 · pagos)
// ---------------------------------------------------------------------------

/// Orden de compra. Al crearse (commit), los asientos pasan a `sold` dentro de
/// una transacción con SELECT ... FOR UPDATE (0 doble-venta). Los totales son un
/// snapshot inmutable del PricingEngine (server-authoritative). Dinero en Decimal.
model Order {
  id       String      @id @default(uuid()) @db.Uuid
  buyerId  String      @map("buyer_id") @db.Uuid
  eventId  String      @map("event_id") @db.Uuid
  status   OrderStatus @default(pending)
  currency String      @default("GTQ")

  // Snapshot de totales (suma de los ítems). Nunca `number` para dinero.
  net         Decimal @db.Decimal(12, 2)
  fixedFees   Decimal @default(0) @db.Decimal(12, 2)
  platformFee Decimal @db.Decimal(12, 2)
  taxableBase Decimal @db.Decimal(12, 2)
  iva         Decimal @db.Decimal(12, 2)
  gatewayFee  Decimal @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  // Versión de comisiones usada (reproduce la cotización de forma auditable).
  feeScheduleId      String? @map("fee_schedule_id") @db.Uuid
  feeScheduleVersion Int?    @map("fee_schedule_version")

  // Facturación electrónica (FEL, Guatemala). NIT 'CF' = consumidor final.
  // Los campos de autorización se llenan al certificar la factura (Ola 3+).
  billingNit     String    @default("CF") @map("billing_nit")
  billingName    String?   @map("billing_name")
  billingAddress String?   @map("billing_address")
  felUuid        String?   @map("fel_uuid")
  felSerie       String?   @map("fel_serie")
  felNumero      String?   @map("fel_numero")
  felCertifiedAt DateTime? @map("fel_certified_at")

  expiresAt   DateTime? @map("expires_at")
  paidAt      DateTime? @map("paid_at")
  cancelledAt DateTime? @map("cancelled_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  buyer       User         @relation(fields: [buyerId], references: [id])
  event       Event        @relation(fields: [eventId], references: [id])
  feeSchedule FeeSchedule? @relation(fields: [feeScheduleId], references: [id])
  items       OrderItem[]

  @@index([buyerId])
  @@index([eventId])
  @@index([status])
  @@map("orders")
}

/// Línea de una orden = un asiento (o cupo general). Guarda el PriceQuote
/// completo del PricingEngine como snapshot inmutable (jsonb). `active` = false
/// al cancelar/reembolsar: libera el asiento y el índice único parcial.
model OrderItem {
  id         String  @id @default(uuid()) @db.Uuid
  orderId    String  @map("order_id") @db.Uuid
  localityId String  @map("locality_id") @db.Uuid
  seatId     String? @map("seat_id") @db.Uuid // null = admisión general (aforo)
  label      String?

  // Snapshot de precio por ítem.
  net       Decimal @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)
  quote     Json // PriceQuote íntegro (incluye hash anti-manipulación)
  quoteHash String  @map("quote_hash")

  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  locality Locality @relation(fields: [localityId], references: [id])
  seat     Seat?    @relation(fields: [seatId], references: [id])

  @@index([orderId])
  @@index([seatId])
  @@map("order_items")
}

// ---------------------------------------------------------------------------
// Ledger contable de partida doble con hash-chain (Ola 3)
// ---------------------------------------------------------------------------

/// Cuenta contable. El saldo (`balance`) se cachea y se actualiza dentro de la
/// misma transacción que asienta los movimientos (derivable de sus entries).
/// Cuentas de usuario/promotor: `ownerId` = user.id; cuentas de sistema: null.
model LedgerAccount {
  id        String            @id @default(uuid()) @db.Uuid
  type      LedgerAccountType
  ownerId   String?           @map("owner_id") @db.Uuid
  currency  String            @default("GTQ")
  balance   Decimal           @default(0) @db.Decimal(14, 2)
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  entries LedgerEntry[]

  @@unique([type, ownerId, currency])
  @@index([ownerId])
  @@map("ledger_accounts")
}

/// Transacción contable: agrupa ≥2 asientos que SUMAN 0 (partida doble).
/// Encadenada por hash (blockchain): hash = sha256(prevHash + contenido canónico).
/// Append-only e inmutable; `seq` da el orden del chain.
model LedgerTransaction {
  id        String   @id @default(uuid()) @db.Uuid
  seq       BigInt    @unique @default(autoincrement())
  kind      String // 'order_payment' | 'wallet_topup' | 'payout' | 'refund' | 'chargeback'
  refType   String?  @map("ref_type") // p.ej. 'order'
  refId     String?  @map("ref_id") @db.Uuid
  prevHash  String   @map("prev_hash") // hash de la transacción anterior ('' en génesis)
  hash      String   @unique // sha256(prevHash + seq + kind + entries + createdAt)
  memo      String?
  createdAt DateTime @default(now()) @map("created_at")

  entries LedgerEntry[]

  @@index([refType, refId])
  @@map("ledger_transactions")
}

/// Asiento contable individual. `amount` firmado (Decimal): + acredita, - debita
/// el saldo de la cuenta. La suma de los asientos de una transacción es 0.
model LedgerEntry {
  id            String   @id @default(uuid()) @db.Uuid
  transactionId String   @map("transaction_id") @db.Uuid
  accountId     String   @map("account_id") @db.Uuid
  amount        Decimal  @db.Decimal(14, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  transaction LedgerTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  account     LedgerAccount     @relation(fields: [accountId], references: [id])

  @@index([transactionId])
  @@index([accountId])
  @@map("ledger_entries")
}
