// Prisma schema — Pasa Eventos
// Fuente de verdad: PostgreSQL. Ver docs/ARQUITECTURA.md.
// Ola 0: settings. Ola 1: identidad (users/auth/rbac) + catálogo
// (categories/events/media) + venues (localities/seat_maps/seats).
// El pricing, órdenes, pagos, boletos, transferencias y ledger llegan en 2+.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  admin
  promoter
  promoter_staff
  gate_operator
  buyer
}

enum UserStatus {
  active
  inactive
  pending
}

enum EventStatus {
  draft
  published
  cancelled
  finished
}

enum LocalityKind {
  seated // con mapa de asientos
  general // admisión general (aforo)
}

enum SeatStatus {
  available
  held
  sold
  blocked
}

enum MediaKind {
  cover
  gallery
}

// ---------------------------------------------------------------------------
// Configuración del sistema (Ola 0)
// ---------------------------------------------------------------------------

/// Configuración clave/valor del sistema (editable por el admin).
model Setting {
  key         String   @id
  value       Json
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// ---------------------------------------------------------------------------
// Identidad y autenticación (Ola 1)
// ---------------------------------------------------------------------------

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  passwordHash String     @map("password_hash")
  firstName    String     @map("first_name")
  lastName     String?    @map("last_name")
  phone        String?
  avatarUrl    String?    @map("avatar_url")
  status       UserStatus @default(active)
  roles        Role[]     @default([buyer])
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  events        Event[]            @relation("EventPromoter")
  refreshTokens RefreshToken[]
  recoveries    PasswordRecovery[]
  categories    Category[]

  @@index([status])
  @@map("users")
}

/// Refresh tokens con rotación y detección de reuso (por "family").
model RefreshToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  tokenHash    String    @unique @map("token_hash")
  family       String    @db.Uuid
  userAgent    String?   @map("user_agent")
  ip           String?
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  replacedById String?   @map("replaced_by_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([family])
  @@map("refresh_tokens")
}

model PasswordRecovery {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_recoveries")
}

// ---------------------------------------------------------------------------
// Catálogo (Ola 1)
// ---------------------------------------------------------------------------

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  active      Boolean  @default(true)
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)
  events    Event[]

  @@index([active])
  @@map("categories")
}

model Event {
  id          String      @id @default(uuid()) @db.Uuid
  promoterId  String      @map("promoter_id") @db.Uuid
  categoryId  String?     @map("category_id") @db.Uuid
  name        String
  slug        String      @unique
  description String?
  address     String?
  lat         Float?
  lng         Float?
  startsAt    DateTime    @map("starts_at")
  endsAt      DateTime    @map("ends_at")
  status      EventStatus @default(draft)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  promoter   User        @relation("EventPromoter", fields: [promoterId], references: [id])
  category   Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  localities Locality[]
  media      EventMedia[]
  seatMaps   SeatMap[]

  @@index([promoterId])
  @@index([status])
  @@index([startsAt])
  @@map("events")
}

model EventMedia {
  id        String    @id @default(uuid()) @db.Uuid
  eventId   String    @map("event_id") @db.Uuid
  key       String // clave del objeto en el bucket
  kind      MediaKind @default(gallery)
  position  Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_media")
}

// ---------------------------------------------------------------------------
// Venues: localidades, mapas de asiento (versionados) y asientos (Ola 1)
// ---------------------------------------------------------------------------

model Locality {
  id        String       @id @default(uuid()) @db.Uuid
  eventId   String       @map("event_id") @db.Uuid
  name      String
  slug      String
  kind      LocalityKind @default(general)
  capacity  Int          @default(0)
  /// Ganancia neta deseada por el promotor (input). El precio de venta se
  /// calcula en la Ola 2 (PricingEngine); aquí solo se captura el input.
  desiredNet Decimal?    @map("desired_net") @db.Decimal(12, 2)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  event Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  seats Seat[]

  @@unique([eventId, slug])
  @@index([eventId])
  @@map("localities")
}

/// Mapa de asientos versionado (inmutable por versión). El layout SVG/geometría
/// se guarda como jsonb; los asientos individuales viven en `seats`.
model SeatMap {
  id         String   @id @default(uuid()) @db.Uuid
  eventId    String   @map("event_id") @db.Uuid
  version    Int      @default(1)
  name       String?
  width      Int      @default(1000)
  height     Int      @default(800)
  background Json?
  layout     Json     @default("{}")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, version])
  @@index([eventId])
  @@map("seat_maps")
}

model Seat {
  id         String     @id @default(uuid()) @db.Uuid
  localityId String     @map("locality_id") @db.Uuid
  section    String?
  row        String?
  label      String
  x          Float?
  y          Float?
  status     SeatStatus @default(available)
  createdAt  DateTime   @default(now()) @map("created_at")

  locality Locality @relation(fields: [localityId], references: [id], onDelete: Cascade)

  @@unique([localityId, label])
  @@index([localityId])
  @@index([status])
  @@map("seats")
}
