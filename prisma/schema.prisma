// Prisma schema â€” Pasa Eventos
// Fuente de verdad: PostgreSQL. Ver docs/ARQUITECTURA.md.
// Ola 0: settings. Ola 1: identidad (users/auth/rbac) + catĂˇlogo
// (categories/events/media) + venues (localities/seat_maps/seats).
// El pricing, Ăłrdenes, pagos, boletos, transferencias y ledger llegan en 2+.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  admin
  advisor // asesor de soporte: hace lo del admin MENOS la tab "Sistema"; muta con desbloqueo por link del admin (B2)
  promoter
  promoter_staff
  gate_operator
  buyer
}

/// Desbloqueo temporal de un ASESOR para MUTAR (B2). El asesor lo solicita y se
/// aprueba desde un enlace que recibe el ADMIN; abre una ventana de tiempo.
model AdvisorUnlock {
  id           String    @id @default(uuid()) @db.Uuid
  advisorId    String    @map("advisor_id") @db.Uuid
  tokenHash    String    @unique @map("token_hash") // sha256 del token del enlace (se muestra una vez)
  approved     Boolean   @default(false)
  approvedById String?   @map("approved_by_id") @db.Uuid
  approvedAt   DateTime? @map("approved_at")
  expiresAt    DateTime? @map("expires_at") // fin de la ventana (se fija al aprobar)
  createdAt    DateTime  @default(now()) @map("created_at")

  advisor    User  @relation("advisorUnlocks", fields: [advisorId], references: [id], onDelete: Cascade)
  approvedBy User? @relation("advisorUnlocksApproved", fields: [approvedById], references: [id])

  @@index([advisorId])
  @@map("advisor_unlocks")
}

/// Estado de un ticket de soporte (T1). MĂˇquina de estados formal:
/// new â†’ open (asignado) â†’ awaiting_promoter/awaiting_support â†’ resolved â†’ closed.
/// Transversales: suspended (congela el reloj SLA), reopened (promotor responde tras resolved).
enum SupportStatus {
  new
  open
  awaiting_promoter
  awaiting_support
  resolved
  closed
  suspended
  reopened
}

/// CategorĂ­a del ticket (enrutamiento al agente correcto + mĂ©tricas).
enum SupportCategory {
  billing
  payments_settlement
  event
  technical
  account
  other
}

/// Prioridad del ticket (define el objetivo de SLA de 1ÂŞ respuesta y resoluciĂłn).
enum SupportPriority {
  low
  medium
  high
  urgent
}

/// Tipo de recurso ligado al ticket (da contexto al agente), opcional.
enum SupportContextType {
  event
  order
  settlement
}

/// Ticket de soporte de un promotor (T1; evoluciona el chat B3). El chat vive DENTRO
/// del ticket (los mensajes en vivo). Estados formales + SLA + archivar (no borrar).
model SupportTicket {
  id           String          @id @default(uuid()) @db.Uuid
  promoterId   String          @map("promoter_id") @db.Uuid
  subject      String
  category     SupportCategory @default(other)
  priority     SupportPriority @default(medium)
  status       SupportStatus   @default(new)
  assignedToId String?         @map("assigned_to_id") @db.Uuid

  /// Contexto opcional: evento / orden / liquidaciĂłn ligados al reclamo.
  contextType SupportContextType? @map("context_type")
  contextId   String?             @map("context_id") @db.Uuid

  /// SLA (reloj). Los *DueAt se calculan por prioridad; el reloj se PAUSA en
  /// suspended y awaiting_promoter (se recalcula al reanudar). Los *At son marcas.
  firstResponseDueAt DateTime? @map("first_response_due_at")
  resolveDueAt       DateTime? @map("resolve_due_at")
  firstRespondedAt   DateTime? @map("first_responded_at")
  resolvedAt         DateTime? @map("resolved_at")
  closedAt           DateTime? @map("closed_at")
  suspendedAt        DateTime? @map("suspended_at")
  /// Marca desde cuĂˇndo el reloj SLA estĂˇ en pausa (awaiting_promoter/suspended);
  /// al reanudar se corren los *DueAt por el tiempo pausado y se limpia.
  slaPausedAt        DateTime? @map("sla_paused_at")
  /// Marcas de incumplimiento ya alertado (idempotencia del job de breach).
  firstResponseBreachedAt DateTime? @map("first_response_breached_at")
  resolveBreachedAt       DateTime? @map("resolve_breached_at")

  /// El promotor ARCHIVA (oculta su vista); NO se borra â†’ no-repudio y trazabilidad.
  archivedByPromoterAt DateTime? @map("archived_by_promoter_at")

  /// SatisfacciĂłn al cerrar (1..5), opcional.
  csatScore Int? @map("csat_score")

  lastMessageAt DateTime @default(now()) @map("last_message_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  promoter   User             @relation("supportPromoter", fields: [promoterId], references: [id], onDelete: Cascade)
  assignedTo User?            @relation("supportAssigned", fields: [assignedToId], references: [id])
  messages   SupportMessage[]

  @@index([promoterId])
  @@index([assignedToId])
  @@index([status, lastMessageAt])
  @@index([firstResponseDueAt])
  @@index([resolveDueAt])
  @@map("support_tickets")
}

/// Respuesta rĂˇpida / macro (T2): texto reutilizable que un agente inserta al responder,
/// por idioma y (opcional) categorĂ­a. Acelera la atenciĂłn y mantiene tono consistente.
model SupportCannedResponse {
  id          String           @id @default(uuid()) @db.Uuid
  title       String
  body        String
  lang        String           @default("es")
  category    SupportCategory?
  createdById String?          @map("created_by_id") @db.Uuid
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  createdBy User? @relation("supportMacroAuthor", fields: [createdById], references: [id])

  @@index([lang])
  @@map("support_canned_responses")
}

/// ArtĂ­culo de la Base de Conocimientos (T6). Fuente de verdad para el FAQ pĂşblico
/// (SSR + JSON-LD) y para el chat/bot vĂ­a KbAutoResponder. SEPARADO de las macros:
/// las macros son textos que el agente inserta; el KB es contenido publicable con
/// editor de formato. `answerHtml` = respuesta con formato (sanitizada); `answerText`
/// = texto plano derivado (bĂşsqueda + JSON-LD acceptedAnswer). `visibility` public =
/// FAQ pĂşblico; internal = solo para agentes/bot (no se expone en el FAQ).
model KbArticle {
  id          String        @id @default(uuid()) @db.Uuid
  slug        String        @unique
  question    String
  answerHtml  String        @map("answer_html")
  answerText  String        @map("answer_text")
  category    SupportCategory?
  locale      String        @default("es")
  status      ContentStatus @default(draft)
  visibility  KbVisibility  @default(public)
  tags        String[]      @default([])
  sortOrder   Int           @default(0) @map("sort_order")
  viewCount   Int           @default(0) @map("view_count")
  createdById String?       @map("created_by_id") @db.Uuid
  publishedAt DateTime?     @map("published_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  createdBy User? @relation("kbArticleAuthor", fields: [createdById], references: [id])

  @@index([status, visibility, locale])
  @@index([category])
  @@map("kb_articles")
}

/// Visibilidad de un artĂ­culo del KB: pĂşblico (FAQ) o interno (solo agentes/bot).
enum KbVisibility {
  public
  internal
}

/// Mensaje de un ticket de soporte (T1). `senderRole` audita quiĂ©n hablĂł.
/// `internalNote` = nota del agente NO visible para el promotor.
model SupportMessage {
  id           String    @id @default(uuid()) @db.Uuid
  ticketId     String    @map("ticket_id") @db.Uuid
  senderId     String    @map("sender_id") @db.Uuid
  senderRole   Role      @map("sender_role")
  body         String
  internalNote Boolean   @default(false) @map("internal_note")
  readByAgentAt    DateTime? @map("read_by_agent_at")
  readByPromoterAt DateTime? @map("read_by_promoter_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  ticket      SupportTicket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender      User                @relation("supportSender", fields: [senderId], references: [id])
  attachments SupportAttachment[]

  @@index([ticketId, createdAt])
  @@map("support_messages")
}

/// Adjunto de un mensaje de soporte (T4): archivo en storage (captura, comprobante).
/// Solo se guarda la referencia (key + metadatos); el binario vive en S3/GCS y se
/// sirve con URL firmada de corta duraciĂłn.
model SupportAttachment {
  id         String   @id @default(uuid()) @db.Uuid
  messageId  String   @map("message_id") @db.Uuid
  storageKey String   @map("storage_key")
  filename   String
  mime       String
  size       Int
  createdAt  DateTime @default(now()) @map("created_at")

  message SupportMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("support_attachments")
}

/// NotificaciĂłn in-app (T5) para promotores/admins. `type` es una cadena libre
/// (documentada) para no migrar al aĂ±adir disparadores; el frontend mapea typeâ†’i18n.
/// `payload` lleva datos extra (montos, ids) para render/enlace. `readAt` = leĂ­da.
model Notification {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  type         String
  title        String
  body         String?
  payload      Json?
  resourceType String?   @map("resource_type")
  resourceId   String?   @map("resource_id") @db.Uuid
  readAt       DateTime? @map("read_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation("userNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

/// Preferencia de notificaciĂłn por usuario/tipo/canal (T5). Ausente â†’ default ON.
model NotificationPreference {
  id      String  @id @default(uuid()) @db.Uuid
  userId  String  @map("user_id") @db.Uuid
  type    String
  channel String
  enabled Boolean @default(true)

  user User @relation("userNotifPrefs", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, channel])
  @@map("notification_preferences")
}

enum UserStatus {
  active
  inactive
  pending
}

enum EventStatus {
  draft
  published
  suspended // despublicado para reconfigurarse (cambio de salĂłn/plantilla); re-publicable
  cancelled
  finished
}

enum LocalityKind {
  seated // con mapa de asientos
  general // admisiĂłn general (aforo)
}

enum SeatStatus {
  available
  held
  sold
  blocked
}

enum MediaKind {
  cover
  gallery
}

enum TwoFactorMethod {
  email
  totp
}

/// PropĂłsito de un cĂłdigo/enlace enviado por correo.
enum ChallengePurpose {
  email_verify // verificar el correo
  passwordless // inicio de sesiĂłn sin contraseĂ±a (magic link + cĂłdigo)
  twofa_email // segundo factor por correo
  gateway_unlock // desbloqueo por OTP para agregar una pasarela (acciĂłn sensible, admin)
  event_edit_unlock // desbloqueo por OTP para que un ADMIN edite un evento ajeno (token 5 min)
}

/// Tipo/preset de una plantilla de disposiciĂłn de asientos (v3.5). Los cuatro
/// primeros replican las plantillas built-in del editor; `custom` = creada por admin.
enum SeatTemplateKind {
  rows // filas rectas
  theater // filas curvadas hacia el escenario
  stadium // gradas en los cuatro lados de la cancha
  tables // mesas redondas
  grid // cuadrĂ­cula genĂ©rica
  curve // lĂ­nea/arco curvo
  line // lĂ­nea recta
  custom // definida a mano
}

/// Estado de publicaciĂłn de contenido gestionable por admin (salones, plantillas
/// de asientos, v3.7): `draft` = solo lo ve el admin en su consola; `published` =
/// visible para el promotor (selector de salĂłn / desplegable de plantillas).
enum ContentStatus {
  draft
  published
}

/// Estado de un intento de pago.
enum PaymentStatus {
  pending // creado; esperando confirmaciĂłn del webhook
  succeeded // confirmado (fulfillment hecho)
  failed // rechazado por la pasarela
  refunded // reembolsado tras haber sido exitoso
}

/// MĂ©todo de pago de un intento.
enum PaymentMethod {
  gateway // 100% pasarela
  wallet // 100% saldo interno
  mixed // saldo interno + pasarela (Ola 3 Â· pago mixto)
}

/// Estado operativo de una pasarela de pago configurada.
enum GatewayStatus {
  active // disponible para cobrar
  inactive // deshabilitada (no se puede usar; solo si no estĂˇ en uso)
  maintenance // en mantenimiento (compras cerradas temporalmente)
}

/// Tipo de cuenta contable del ledger (partida doble).
enum LedgerAccountType {
  user_wallet // saldo interno del usuario (pasivo de la plataforma con el usuario)
  promoter_payable // lo que la plataforma debe al promotor (neto por liquidar)
  platform_revenue // ingreso de la plataforma (comisiones)
  tax_payable // IVA por pagar al fisco
  gateway_clearing // dinero en trĂˇnsito por la pasarela (liquidaciĂłn)
  gateway_fee // costo de la comisiĂłn de pasarela
  payment_holding // fondos de wallet reservados durante un pago mixto (en trĂˇnsito)
  platform_expense // gastos extra (fuera del precio del boleto) compartidos promotorâ†”plataforma
  payout_pending // retiro de wallet reservado, pendiente de pago externo (neto al usuario)
  payout_settled // retiros ya pagados externamente (acumulado)
}

/// Estado de una solicitud de retiro de saldo interno (Ola 6).
enum WithdrawalStatus {
  pending // solicitada; saldo reservado; espera aprobaciĂłn del admin
  approved // aprobada por el admin; pendiente de pago externo
  paid // pagada (transferencia externa realizada)
  rejected // rechazada por el admin (se reintegra el saldo)
  cancelled // cancelada por el usuario (se reintegra el saldo)
}

/// Estado de un boleto emitido (Ola 4).
enum TicketStatus {
  valid // emitido y vĂˇlido
  used // ya validado en puerta (check-in)
  transferred // transferido a otro dueĂ±o; re-emitido (Ola 5)
  revoked // invalidado (reembolso/contracargo)
}

/// Tipo de movimiento en la cadena de custodia de un boleto (Ola 5).
enum TicketEventType {
  issued // emisiĂłn inicial
  transferred // regalo interno a otro dueĂ±o (re-emisiĂłn)
  checked_in // validado en puerta
  revoked // invalidado (reembolso/contracargo)
}

/// Estado de una transferencia (regalo) de boleto (Ola 5).
enum TransferStatus {
  pending // iniciada por el remitente; espera que el destinatario canjee el cĂłdigo
  claimed // canjeada (boleto re-emitido al destinatario)
  cancelled // cancelada por el remitente
  expired // venciĂł sin canjearse
}

/// Estado de autorizaciĂłn de un usuario como promotor (Ola 4). Cualquier usuario
/// puede solicitar; un admin autoriza antes de que pueda operar. El "modo pruebas"
/// (setting `promoters.require_approval` = false) auto-aprueba al solicitar.
enum PromoterStatus {
  none // no ha solicitado ser promotor
  pending // solicitĂł; espera autorizaciĂłn del admin
  approved // autorizado; puede crear/publicar eventos y cobrar
  rejected // solicitud rechazada
  suspended // autorizaciĂłn revocada por el admin
}

/// Plan del promotor (pantalla de pricing). `free` = plan actual con lĂ­mites; `premium`
/// = acceso a todo. El enforcement fino de lĂ­mites por plan es incremental por feature.
enum PromoterTier {
  free
  premium
}

/// Estado de una invitaciĂłn de promotor por token (Ola F4).
enum PromoterInvitationStatus {
  pending // enviada; el token sigue vigente
  accepted // el destinatario se registrĂł y quedĂł auto-aprobado
  revoked // cancelada por quien invitĂł
  expired // venciĂł sin usarse
}

/// Estado de una orden de compra.
enum OrderStatus {
  pending // creada; asientos ya reservados (sold) a la espera de pago
  paid // pagada y confirmada (fulfillment)
  cancelled // cancelada por el usuario o el sistema
  expired // venciĂł la ventana de pago sin completarse
  refunded // reembolsada tras el pago
}

// ---------------------------------------------------------------------------
// ConfiguraciĂłn del sistema (Ola 0)
// ---------------------------------------------------------------------------

/// ConfiguraciĂłn clave/valor del sistema (editable por el admin).
model Setting {
  key         String   @id
  value       Json
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// ---------------------------------------------------------------------------
// Identidad y autenticaciĂłn (Ola 1)
// ---------------------------------------------------------------------------

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  // Opcional: usuarios solo-Google o passwordless pueden no tener contraseĂ±a.
  passwordHash String?    @map("password_hash")
  firstName    String     @map("first_name")
  lastName     String?    @map("last_name")
  phone        String?
  avatarUrl    String?    @map("avatar_url")
  status       UserStatus @default(active)
  roles        Role[]     @default([buyer])
  /// Marca que el usuario fue asesor alguna vez (se pone al deshabilitarlo) â†’ el panel
  /// de asesores sigue mostrĂˇndolo aunque ya no tenga el rol, para poder eliminarlo.
  wasAdvisor   Boolean    @default(false) @map("was_advisor")

  // Preferencia de idioma del usuario (v3.7): 'es' | 'en'. Se persiste desde el
  // perfil y se aplica en el frontend por encima de la preferencia de localStorage.
  language     String     @default("es")

  // Preferencia de FRANJA de tema del usuario (rebranding Boletiva): 'dia' | 'noche'
  // | null (null = usa la franja por defecto de la plataforma). El tema concreto lo
  // resuelve la asignaciĂłn admin franjaâ†’tema. Solo aplica si el admin permite el switch.
  themePref    String?    @map("theme_pref")

  // T7: preferencia de PERFIL para recibir notificaciones por correo. NO afecta a los
  // correos de SEGURIDAD (OTP/verificaciĂłn/login), que van por otra vĂ­a; solo a las
  // notificaciones de negocio/soporte (NotificationsService canal email).
  emailNotificationsEnabled Boolean @default(true) @map("email_notifications_enabled")

  // Foto de perfil (opcional). Se guarda la KEY del objeto en storage (patrĂłn
  // event-media: firmar al leer); `avatarUrl` de las respuestas se firma en caliente
  // con `StorageService.signedGetUrl`. `avatarUrl` (columna) queda para URLs externas
  // heredadas / Google; si hay `avatarKey` tiene prioridad.
  avatarKey    String?    @map("avatar_key")

  // VerificaciĂłn de correo (null = no verificado).
  emailVerifiedAt DateTime? @map("email_verified_at")

  // 2FA: obligatorio una vez el email estĂˇ verificado. email por defecto; totp opcional.
  twoFactorMethod   TwoFactorMethod @default(email) @map("two_factor_method")
  totpSecret        String?         @map("totp_secret")
  totpPendingSecret String?         @map("totp_pending_secret")

  // % de gastos EXTRA que asume este promotor (null = usa el default global).
  // Los gastos fuera del precio del boleto (p.ej. pasar boleto a wallet) se
  // reparten promotorâ†”plataforma; la parte del promotor se descuenta de su neto.
  costSharePct Decimal? @map("cost_share_pct") @db.Decimal(6, 5)

  // AutorizaciĂłn como promotor (Ola 4). Un usuario puede solicitar ser promotor;
  // un admin lo aprueba antes de que pueda operar (salvo en modo pruebas).
  promoterStatus    PromoterStatus @default(none) @map("promoter_status")
  promoterTier      PromoterTier   @default(free) @map("promoter_tier")
  // Premium (B1): si `premiumTrialEndsAt` estĂˇ en el futuro, el tier premium viene de una
  // PRUEBA GRATIS (al vencer, un job lo baja a free). null con tier=premium = premium PAGADO
  // (permanente, exige tarjeta). `premiumSince` = cuĂˇndo se activĂł premium (informativo).
  premiumTrialEndsAt DateTime? @map("premium_trial_ends_at")
  premiumSince       DateTime? @map("premium_since")
  promoterAppliedAt DateTime?      @map("promoter_applied_at")
  promoterDecidedAt DateTime?      @map("promoter_decided_at")
  promoterNote      String?        @map("promoter_note") // motivo de rechazo/suspensiĂłn
  // Nota interna del admin sobre el promotor (v3.8). Persistente e independiente
  // de `promoterNote` (que es el motivo de la Ăşltima decisiĂłn y se limpia al
  // aprobar). Solo la ve/edita el admin en la consola; no se muestra al promotor.
  promoterInternalNote String? @map("promoter_internal_note")

  // Usuario de PRUEBA (v3.2): promotores invitados marcados como test no pueden
  // usar pasarelas reales (anclados a Sandbox) para no contaminar mĂ©tricas de prod.
  isTestUser Boolean @default(false) @map("is_test_user")

  // Datos de FACTURACIĂ“N del usuario (FEL). `nit` se prellena en el checkout y es
  // necesario para facturar (si se borra, el frontend avisa). `billingName` es el
  // nombre fiscal (idealmente autocompletado por el NIT). `dpi` es OPCIONAL.
  // El NIT por defecto para consumidor final es 'CF' (se aplica en el checkout si falta).
  nit         String? @map("nit")
  billingName String? @map("billing_name")
  dpi         String? @map("dpi")

  // Onboarding: tours (por pĂˇgina) que el usuario ya completĂł o saltĂł. Si la clave del
  // tour NO estĂˇ aquĂ­, se le muestra; al completar/skipear se agrega y deja de mostrarse.
  toursSeen   String[] @default([]) @map("tours_seen")

  // Privacidad/retenciĂłn (Ola 6): sello de anonimizaciĂłn (seudonimizaciĂłn de PII
  // preservando el ledger). null = datos personales intactos.
  anonymizedAt DateTime? @map("anonymized_at")

  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  events        Event[]            @relation("EventPromoter")
  // Eventos creados por este usuario (admin) a nombre de otro promotor (v3.8).
  eventsCreatedAsAdmin Event[]     @relation("EventCreatedByAdmin")
  refreshTokens RefreshToken[]
  recoveries    PasswordRecovery[]
  categories    Category[]
  challenges    AuthChallenge[]
  devices       Device[]
  oauthAccounts OAuthAccount[]
  orders        Order[]
  tickets       Ticket[]           @relation("TicketOwner")
  withdrawals   WalletWithdrawal[]
  gateAssignments GateAssignment[] @relation("GateOperator")
  promoterInvitations PromoterInvitation[] @relation("InvitedBy")
  advisorInvitations  AdvisorInvitation[]  @relation("AdvisorInvitedBy")
  validatorInvites ValidatorInvitation[] @relation("ValidatorOperator")
  savedCards SavedCard[]
  advisorUnlocks         AdvisorUnlock[] @relation("advisorUnlocks")
  advisorUnlocksApproved AdvisorUnlock[] @relation("advisorUnlocksApproved")
  supportTickets         SupportTicket[]         @relation("supportPromoter")
  supportTicketsAssigned SupportTicket[]         @relation("supportAssigned")
  supportMessages        SupportMessage[]        @relation("supportSender")
  supportMacros          SupportCannedResponse[] @relation("supportMacroAuthor")
  kbArticles             KbArticle[]             @relation("kbArticleAuthor")
  notifications          Notification[]          @relation("userNotifications")
  notificationPrefs      NotificationPreference[] @relation("userNotifPrefs")

  @@index([status])
  @@map("users")
}

/// Tarjetas guardadas (mĂ©todos de pago) tokenizadas (PCI-DSS). NUNCA se guarda el
/// PAN: la pasarela tokeniza en sus servidores y aquĂ­ solo persistimos el TOKEN
/// opaco reutilizable + la marca y los Ăşltimos 4 dĂ­gitos (no sensibles) para mostrar.
model SavedCard {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  brand     String // visa, mastercard, amex, ...
  last4     String   @db.VarChar(4)
  /// Token opaco devuelto por el tokenizador (referencia, no la tarjeta).
  token     String
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("saved_cards")
}

/// Refresh tokens con rotaciĂłn y detecciĂłn de reuso (por "family").
model RefreshToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  tokenHash    String    @unique @map("token_hash")
  family       String    @db.Uuid
  userAgent    String?   @map("user_agent")
  ip           String?
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  replacedById String?   @map("replaced_by_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([family])
  @@map("refresh_tokens")
}

model PasswordRecovery {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_recoveries")
}

/// CĂłdigos OTP (6 dĂ­gitos) + enlace mĂˇgico, unificados por propĂłsito.
/// Se guardan hasheados; nunca en claro.
model AuthChallenge {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  purpose   ChallengePurpose
  codeHash  String           @map("code_hash") // sha256 del cĂłdigo de 6 dĂ­gitos
  tokenHash String?          @unique @map("token_hash") // sha256 del token del magic link
  attempts  Int              @default(0)
  expiresAt DateTime         @map("expires_at")
  consumedAt DateTime?       @map("consumed_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@map("auth_challenges")
}

/// Dispositivos conocidos por usuario. `trustedAt` != null => pasĂł 2FA y no se
/// vuelve a exigir 2FA en ese dispositivo.
model Device {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  deviceHash String    @map("device_hash") // sha256 del device id del cliente
  userAgent  String?   @map("user_agent")
  ip         String?
  trustedAt  DateTime? @map("trusted_at")
  lastSeenAt DateTime  @default(now()) @map("last_seen_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceHash])
  @@index([userId])
  @@map("devices")
}

/// Cuentas de proveedores OAuth (Google, etc.) vinculadas a un usuario.
model OAuthAccount {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  provider          String // 'google'
  providerAccountId String   @map("provider_account_id")
  createdAt         DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

// ---------------------------------------------------------------------------
// CatĂˇlogo (Ola 1)
// ---------------------------------------------------------------------------

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  active      Boolean  @default(true)
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)
  events    Event[]

  @@index([active])
  @@map("categories")
}

model Event {
  id          String      @id @default(uuid()) @db.Uuid
  promoterId  String      @map("promoter_id") @db.Uuid
  categoryId  String?     @map("category_id") @db.Uuid
  name        String
  slug        String      @unique
  description String?
  address     String?
  lat         Float?
  lng         Float?
  startsAt    DateTime    @map("starts_at")
  endsAt      DateTime    @map("ends_at")
  status      EventStatus @default(draft)

  // Pagos dinĂˇmicos (Ola 3.5): pasarela elegida por el promotor (null = hereda la
  // default de plataforma). `frozenGatewayId` congela la pasarela usada para el
  // precio al recibir la primera compra (los precios ya no cambian). `ivaOnNet`:
  // si el promotor ya pagĂł IVA del boleto â†’ false (IVA solo sobre la comisiĂłn de
  // plataforma). Referencias sin FK para permitir migrar al anular una pasarela.
  gatewayId       String?  @map("gateway_id") @db.Uuid
  frozenGatewayId String?  @map("frozen_gateway_id") @db.Uuid
  ivaOnNet        Boolean  @default(true) @map("iva_on_net")

  // AuditorĂ­a (v3.8): admin que creĂł el evento A NOMBRE de un promotor. null = lo
  // creĂł el propio promotor. El evento SIEMPRE pertenece al promotor (`promoterId`);
  // este campo solo deja rastro de quiĂ©n lo originĂł desde la consola admin.
  createdByAdminId String? @map("created_by_admin_id") @db.Uuid

  // SalĂłn/venue reutilizable (v3.5). Opcional: el promotor puede elegir un salĂłn
  // pre-registrado (con direcciĂłn/coordenadas y layout de asientos) o escribir la
  // direcciĂłn a mano. Al asignarlo se pueden prefijar address/lat/lng si van vacĂ­os.
  hallId String? @map("hall_id") @db.Uuid

  // Cuotas (Ola 6.5): si el promotor ABSORBE el recargo por pago en cuotas
  // (descontĂˇndolo de su neto en el ledger) en lugar de pasĂˇrselo al comprador.
  // false (default) = el recargo lo paga el comprador (gross-up mayor).
  absorbInstallmentCost Boolean @default(false) @map("absorb_installment_cost")

  // MĂˇximo de transferencias (regalo) por boleto (Ola 5). null = usa el default
  // global (setting `transfer.max_per_ticket_default`).
  maxTransfers Int? @map("max_transfers")

  // Destacado editable (slider "hero" del inicio). null = no promocionado; un
  // entero define el ORDEN de prioridad (menor = primero). Lo edita admin/promotor.
  promotedPriority Int? @map("promoted_priority")

  // v3.10: sello de "cierre de caja" â€” cuĂˇndo un ADMIN finalizĂł el evento y
  // transfiriĂł el saldo (neto acumulado) al wallet del promotor. Idempotencia:
  // con esto puesto, la transferencia no se repite.
  cashTransferredAt DateTime? @map("cash_transferred_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  promoter   User        @relation("EventPromoter", fields: [promoterId], references: [id])
  createdByAdmin User?   @relation("EventCreatedByAdmin", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  category   Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  hall       Hall?       @relation(fields: [hallId], references: [id], onDelete: SetNull)
  gateAssignments GateAssignment[]
  validators ValidatorInvitation[]
  localities Locality[]
  media      EventMedia[]
  seatMaps   SeatMap[]
  orders     Order[]
  tickets    Ticket[]

  @@index([promoterId])
  @@index([status])
  @@index([startsAt])
  @@map("events")
}

model EventMedia {
  id        String    @id @default(uuid()) @db.Uuid
  eventId   String    @map("event_id") @db.Uuid
  key       String // clave del objeto en el bucket
  kind      MediaKind @default(gallery)
  position  Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_media")
}

// ---------------------------------------------------------------------------
// Venues: localidades, mapas de asiento (versionados) y asientos (Ola 1)
// ---------------------------------------------------------------------------

model Locality {
  id        String       @id @default(uuid()) @db.Uuid
  eventId   String       @map("event_id") @db.Uuid
  name      String
  slug      String
  kind      LocalityKind @default(general)
  capacity  Int          @default(0)
  /// Ganancia neta deseada por el promotor (input). El precio de venta se
  /// calcula en la Ola 2 (PricingEngine); aquĂ­ solo se captura el input.
  desiredNet Decimal?    @map("desired_net") @db.Decimal(12, 2)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  seats      Seat[]
  orderItems OrderItem[]
  tickets    Ticket[]

  @@unique([eventId, slug])
  @@index([eventId])
  @@map("localities")
}

/// Mapa de asientos versionado (inmutable por versiĂłn). El layout SVG/geometrĂ­a
/// se guarda como jsonb; los asientos individuales viven en `seats`.
model SeatMap {
  id         String   @id @default(uuid()) @db.Uuid
  eventId    String   @map("event_id") @db.Uuid
  version    Int      @default(1)
  name       String?
  width      Int      @default(1000)
  height     Int      @default(800)
  background Json?
  layout     Json     @default("{}")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, version])
  @@index([eventId])
  @@map("seat_maps")
}

model Seat {
  id         String     @id @default(uuid()) @db.Uuid
  localityId String     @map("locality_id") @db.Uuid
  section    String?
  row        String?
  label      String
  x          Float?
  y          Float?
  status     SeatStatus @default(available)
  createdAt  DateTime   @default(now()) @map("created_at")

  locality   Locality    @relation(fields: [localityId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  tickets    Ticket[]

  @@unique([localityId, label])
  @@index([localityId])
  @@index([status])
  @@map("seats")
}

// ---------------------------------------------------------------------------
// Precios: tabla de comisiones versionada (Ola 2)
// ---------------------------------------------------------------------------

/// ConfiguraciĂłn de comisiones VERSIONADA e inmutable. El admin no edita en
/// sitio: crea una versiĂłn nueva y la activa (solo una activa a la vez, vĂ­a
/// Ă­ndice Ăşnico parcial `fee_schedules_one_active`). Cada orden guarda la
/// versiĂłn usada para reproducir su cotizaciĂłn. Porcentajes en [0, 1).
model FeeSchedule {
  id             String   @id @default(uuid()) @db.Uuid
  version        Int      @unique
  label          String?
  platformFeePct Decimal  @map("platform_fee_pct") @db.Decimal(6, 5)
  gatewayFeePct  Decimal  @map("gateway_fee_pct") @db.Decimal(6, 5)
  ivaPct         Decimal  @map("iva_pct") @db.Decimal(6, 5)
  fixedFees      Decimal  @default(0) @map("fixed_fees") @db.Decimal(12, 2)
  active         Boolean  @default(false)
  createdById    String?  @map("created_by_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  orders Order[]

  @@map("fee_schedules")
}

// ---------------------------------------------------------------------------
// Ă“rdenes (Ola 2 Â· commit anti-doble-venta / Ola 3 Â· pagos)
// ---------------------------------------------------------------------------

/// Orden de compra. Al crearse (commit), los asientos pasan a `sold` dentro de
/// una transacciĂłn con SELECT ... FOR UPDATE (0 doble-venta). Los totales son un
/// snapshot inmutable del PricingEngine (server-authoritative). Dinero en Decimal.
model Order {
  id       String      @id @default(uuid()) @db.Uuid
  buyerId  String      @map("buyer_id") @db.Uuid
  eventId  String      @map("event_id") @db.Uuid
  status   OrderStatus @default(pending)
  currency String      @default("GTQ")

  // Snapshot de totales (suma de los Ă­tems). Nunca `number` para dinero.
  net         Decimal @db.Decimal(12, 2)
  fixedFees   Decimal @default(0) @db.Decimal(12, 2)
  platformFee Decimal @db.Decimal(12, 2)
  taxableBase Decimal @db.Decimal(12, 2)
  iva         Decimal @db.Decimal(12, 2)
  gatewayFee  Decimal @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  // VersiĂłn de comisiones usada (reproduce la cotizaciĂłn de forma auditable).
  feeScheduleId      String? @map("fee_schedule_id") @db.Uuid
  feeScheduleVersion Int?    @map("fee_schedule_version")
  feeGatewayId       String? @map("fee_gateway_id") @db.Uuid // pasarela usada en la cotizaciĂłn

  // FacturaciĂłn electrĂłnica (FEL, Guatemala). NIT 'CF' = consumidor final.
  // Los campos de autorizaciĂłn se llenan al certificar la factura (Ola 3+).
  billingNit     String    @default("CF") @map("billing_nit")
  billingName    String?   @map("billing_name")
  billingAddress String?   @map("billing_address")
  felUuid        String?   @map("fel_uuid")
  felSerie       String?   @map("fel_serie")
  felNumero      String?   @map("fel_numero")
  felCertifiedAt DateTime? @map("fel_certified_at")

  expiresAt   DateTime? @map("expires_at")
  paidAt      DateTime? @map("paid_at")
  cancelledAt DateTime? @map("cancelled_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  buyer       User         @relation(fields: [buyerId], references: [id])
  event       Event        @relation(fields: [eventId], references: [id])
  feeSchedule FeeSchedule? @relation(fields: [feeScheduleId], references: [id])
  items       OrderItem[]
  payments    Payment[]
  tickets     Ticket[]

  @@index([buyerId])
  @@index([eventId])
  @@index([status])
  @@map("orders")
}

/// LĂ­nea de una orden = un asiento (o cupo general). Guarda el PriceQuote
/// completo del PricingEngine como snapshot inmutable (jsonb). `active` = false
/// al cancelar/reembolsar: libera el asiento y el Ă­ndice Ăşnico parcial.
model OrderItem {
  id         String  @id @default(uuid()) @db.Uuid
  orderId    String  @map("order_id") @db.Uuid
  localityId String  @map("locality_id") @db.Uuid
  seatId     String? @map("seat_id") @db.Uuid // null = admisiĂłn general (aforo)
  label      String?

  // Snapshot de precio por Ă­tem.
  net       Decimal @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)
  quote     Json // PriceQuote Ă­ntegro (incluye hash anti-manipulaciĂłn)
  quoteHash String  @map("quote_hash")

  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  locality Locality @relation(fields: [localityId], references: [id])
  seat     Seat?    @relation(fields: [seatId], references: [id])
  ticket   Ticket?

  @@index([orderId])
  @@index([seatId])
  @@map("order_items")
}

// ---------------------------------------------------------------------------
// Pasarelas de pago configurables (Ola 3.5 Â· pagos dinĂˇmicos)
// ---------------------------------------------------------------------------

/// Pasarela de pago configurable. Su comisiĂłn (`feePct`) entra al gross-up del
/// precio (dinĂˇmico por mĂ©todo). `credentialsRef` es una REFERENCIA al secreto
/// (nombre en Secret Manager/env), nunca el secreto en claro. Solo una puede ser
/// la default de plataforma (Ă­ndice parcial `payment_gateways_one_default`).
model PaymentGateway {
  id               String        @id @default(uuid()) @db.Uuid
  name             String        @unique
  provider         String // 'simulator' | 'recurrente' | 'pagalo' | 'stripe' | ...
  feePct           Decimal       @map("fee_pct") @db.Decimal(6, 5)
  /// ComisiĂłn efectiva de pasarela POR CANTIDAD DE CUOTAS (Visacuotas/Mastercuotas).
  /// Mapa { "3": 0.08, "6": 0.09, "12": 0.10, "18": 0.14 } = tasa de la pasarela
  /// para N cuotas. null / ausente / clave "1" â†’ pago Ăşnico usa `feePct`. El costo
  /// extra lo absorbe la plataforma (o el promotor si el evento lo marca); el
  /// comprador paga siempre el precio de 1 pago (recargo directo prohibido en GT).
  installmentRates Json?         @map("installment_rates")
  /// Cargo FIJO por transacciĂłn en cuotas (GTQ, p.ej. Q2 de Recurrente). Se suma
  /// al costo que absorbe la plataforma/promotor. null/0 = sin fijo.
  installmentFixedFee Decimal?   @map("installment_fixed_fee") @db.Decimal(12, 2)
  /// Ola 6.6: cargo FIJO por transacciĂłn que aplica a TODO cobro (pago Ăşnico y
  /// cuotas). Se grossea como el %; el comprador lo paga por boleto y al combinar
  /// N boletos en 1 transacciĂłn la plataforma captura (N-1)Â·fijo. Pagalo = 0.
  transactionFixedFee Decimal   @default(0) @map("transaction_fixed_fee") @db.Decimal(12, 2)
  /// Ola 6.6: % MĂŤNIMO de cost-share del promotor para poder USAR esta pasarela
  /// (0 = disponible para todos; p.ej. PayPal 0.50). La pasarela default del
  /// sistema ignora este umbral (siempre vendible).
  minCostSharePct  Decimal       @default(0) @map("min_cost_share_pct") @db.Decimal(6, 5)
  /// Permite el pago en CUOTAS con esta pasarela. false = solo 1 pago (el checkout
  /// oculta todo lo de cuotas) aunque `installmentRates` tenga tarifario. Perilla del
  /// admin para apagar cuotas sin borrar las tasas configuradas.
  installmentsEnabled Boolean    @default(true) @map("installments_enabled")
  credentialsRef   String?       @map("credentials_ref")
  status           GatewayStatus @default(active)
  isPlatformDefault Boolean      @default(false) @map("is_platform_default")
  sandbox          Boolean       @default(false)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  @@index([status])
  @@map("payment_gateways")
}

// ---------------------------------------------------------------------------
// Pagos: puerto PaymentProvider + webhooks (Ola 3)
// ---------------------------------------------------------------------------

/// Intento de pago de una orden. El fulfillment se dispara por WEBHOOK de la
/// pasarela (webhook-first): la orden queda pending hasta payment.succeeded.
model Payment {
  id           String        @id @default(uuid()) @db.Uuid
  orderId      String        @map("order_id") @db.Uuid
  provider     String // 'simulator' | 'pagalo' | ...
  providerRef  String        @unique @map("provider_ref") // referencia en la pasarela
  method       PaymentMethod @default(gateway)
  status       PaymentStatus @default(pending)
  // Monto cobrado por la pasarela y monto cubierto con saldo interno (pago mixto).
  amount       Decimal       @db.Decimal(12, 2)
  walletAmount Decimal       @default(0) @map("wallet_amount") @db.Decimal(12, 2)
  currency     String        @default("GTQ")
  failureReason String?      @map("failure_reason")
  succeededAt  DateTime?     @map("succeeded_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@map("payments")
}

/// Evento de webhook recibido (idempotencia + auditorĂ­a). El par (provider,
/// eventId) es Ăşnico: reintentos/replays no se reprocesan.
model WebhookEvent {
  id          String    @id @default(uuid()) @db.Uuid
  provider    String
  eventId     String    @map("event_id") // id del evento en la pasarela
  type        String
  providerRef String?   @map("provider_ref")
  payload     Json
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([provider, eventId])
  @@map("webhook_events")
}

// ---------------------------------------------------------------------------
// Ledger contable de partida doble con hash-chain (Ola 3)
// ---------------------------------------------------------------------------

/// Cuenta contable. El saldo (`balance`) se cachea y se actualiza dentro de la
/// misma transacciĂłn que asienta los movimientos (derivable de sus entries).
/// Cuentas de usuario/promotor: `ownerId` = user.id; cuentas de sistema: null.
model LedgerAccount {
  id        String            @id @default(uuid()) @db.Uuid
  type      LedgerAccountType
  ownerId   String?           @map("owner_id") @db.Uuid
  currency  String            @default("GTQ")
  balance   Decimal           @default(0) @db.Decimal(14, 2)
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  entries LedgerEntry[]

  @@unique([type, ownerId, currency])
  @@index([ownerId])
  @@map("ledger_accounts")
}

/// TransacciĂłn contable: agrupa â‰Ą2 asientos que SUMAN 0 (partida doble).
/// Encadenada por hash (blockchain): hash = sha256(prevHash + contenido canĂłnico).
/// Append-only e inmutable; `seq` da el orden del chain.
model LedgerTransaction {
  id        String   @id @default(uuid()) @db.Uuid
  seq       BigInt    @unique @default(autoincrement())
  kind      String // 'order_payment' | 'wallet_topup' | 'payout' | 'refund' | 'chargeback'
  refType   String?  @map("ref_type") // p.ej. 'order'
  refId     String?  @map("ref_id") @db.Uuid
  prevHash  String   @map("prev_hash") // hash de la transacciĂłn anterior ('' en gĂ©nesis)
  hash      String   @unique // sha256(prevHash + seq + kind + entries + createdAt)
  memo      String?
  createdAt DateTime @default(now()) @map("created_at")

  entries LedgerEntry[]

  @@index([refType, refId])
  @@map("ledger_transactions")
}

/// Asiento contable individual. `amount` firmado (Decimal): + acredita, - debita
/// el saldo de la cuenta. La suma de los asientos de una transacciĂłn es 0.
model LedgerEntry {
  id            String   @id @default(uuid()) @db.Uuid
  transactionId String   @map("transaction_id") @db.Uuid
  accountId     String   @map("account_id") @db.Uuid
  amount        Decimal  @db.Decimal(14, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  transaction LedgerTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  account     LedgerAccount     @relation(fields: [accountId], references: [id])

  @@index([transactionId])
  @@index([accountId])
  @@map("ledger_entries")
}

// ---------------------------------------------------------------------------
// Boletos: firma Ed25519 + QR rotativo (TOTP), emisiĂłn async (Ola 4)
// ---------------------------------------------------------------------------

/// Boleto emitido (uno por lĂ­nea de orden). La emisiĂłn se ENCOLA (BullMQ) tras
/// asentar el pago en el ledger, para no bloquear el event loop ni el webhook.
/// La identidad inmutable va firmada con Ed25519 (anti-falsificaciĂłn); un secreto
/// TOTP por boleto (cifrado en reposo) produce un QR ROTATIVO (un screenshot no
/// sirve). La validaciĂłn offline dinĂˇmica + manifiesto se completa en la Ola 5.
model Ticket {
  id          String       @id @default(uuid()) @db.Uuid
  orderItemId String       @unique @map("order_item_id") @db.Uuid
  orderId     String       @map("order_id") @db.Uuid
  eventId     String       @map("event_id") @db.Uuid
  localityId  String       @map("locality_id") @db.Uuid
  seatId      String?      @map("seat_id") @db.Uuid
  ownerId     String       @map("owner_id") @db.Uuid // dueĂ±o actual (comprador)
  serial      String       @unique // id pĂşblico legible (base del QR)
  status      TicketStatus @default(valid)

  // CriptografĂ­a del boleto.
  signature    String // firma Ed25519 (base64) sobre la identidad inmutable
  signingKeyId String @map("signing_key_id") // id de la llave usada (rotaciĂłn)
  totpSecret   String @map("totp_secret") // secreto base32 CIFRADO (AES-256-GCM)

  // Media generada de forma asĂ­ncrona (claves en el bucket).
  qrKey        String?   @map("qr_key")
  pdfKey       String?   @map("pdf_key")
  mediaReadyAt DateTime? @map("media_ready_at")

  // Transferencias (regalo interno, Ola 5): nÂş de veces ya transferido.
  transferCount Int @default(0) @map("transfer_count")

  usedAt    DateTime? @map("used_at")
  revokedAt DateTime? @map("revoked_at")
  issuedAt  DateTime  @default(now()) @map("issued_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  order     Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem OrderItem            @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  event     Event                @relation(fields: [eventId], references: [id])
  owner     User                 @relation("TicketOwner", fields: [ownerId], references: [id])
  seat      Seat?                @relation(fields: [seatId], references: [id])
  locality  Locality             @relation(fields: [localityId], references: [id])
  custody   TicketCustodyEvent[]
  transfers TicketTransfer[]

  @@index([ownerId])
  @@index([eventId])
  @@index([orderId])
  @@index([status])
  @@map("tickets")
}

/// Cadena de custodia de un boleto (Ola 5): bitĂˇcora append-only encadenada por
/// hash (blockchain) de cada movimiento (emisiĂłnâ†’transferenciaâ†’check-inâ†’revocaciĂłn).
/// Huella inborrable; `seq` da el orden dentro del boleto y `prevHash` enlaza.
model TicketCustodyEvent {
  id          String          @id @default(uuid()) @db.Uuid
  ticketId    String          @map("ticket_id") @db.Uuid
  seq         Int // orden dentro del boleto (1..n)
  type        TicketEventType
  fromOwnerId String?         @map("from_owner_id") @db.Uuid
  toOwnerId   String?         @map("to_owner_id") @db.Uuid
  actorId     String?         @map("actor_id") @db.Uuid // quiĂ©n ejecutĂł el movimiento
  prevHash    String          @map("prev_hash") // hash del evento anterior del boleto ('' en gĂ©nesis)
  hash        String          @unique // sha256(prevHash + ticketId + seq + type + from + to + createdAt)
  meta        Json?
  createdAt   DateTime        @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([ticketId, seq])
  @@index([ticketId])
  @@map("ticket_custody_events")
}

/// Transferencia (regalo interno) de un boleto (Ola 5). Handshake de doble
/// confirmaciĂłn: el remitente inicia y recibe un cĂłdigo (guardado hasheado); el
/// destinatario verificado lo canjea. Solo puede haber UNA pendiente por boleto
/// (Ă­ndice parcial `ticket_transfers_one_pending`).
model TicketTransfer {
  id          String         @id @default(uuid()) @db.Uuid
  ticketId    String         @map("ticket_id") @db.Uuid
  senderId    String         @map("sender_id") @db.Uuid
  recipientId String?        @map("recipient_id") @db.Uuid
  codeHash    String         @map("code_hash") // sha256 del cĂłdigo comĂşn
  status      TransferStatus @default(pending)
  expiresAt   DateTime       @map("expires_at")
  claimedAt   DateTime?      @map("claimed_at")
  createdAt   DateTime       @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([codeHash])
  @@map("ticket_transfers")
}

/// Conflicto de validaciĂłn detectado al ingerir check-ins masivos (Ola 6): un
/// boleto que llegĂł a validarse en mĂˇs de una puerta (doble entrada). Se registra
/// para revisiĂłn del organizador; no bloquea el ingest (idempotente).
model CheckinConflict {
  id          String   @id @default(uuid()) @db.Uuid
  ticketId    String   @map("ticket_id") @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  serial      String
  gateId      String?  @map("gate_id") // puerta que reintentĂł validar
  reason      String // 'already_used' | ...
  attemptedAt DateTime @map("attempted_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([eventId])
  @@index([ticketId])
  @@map("checkin_conflicts")
}

/// Solicitud de retiro de saldo interno (Ola 6). Flujo solicitudâ†’aprobaciĂłnâ†’pago.
/// Al solicitar se RESERVA el saldo en el ledger (user_walletâ†’payout_pending +
/// comisiĂłn a la plataforma); rechazar/cancelar lo reintegra; pagar lo liquida.
/// La comisiĂłn del usuario es el doble que la del promotor.
model WalletWithdrawal {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  amount      Decimal          @db.Decimal(12, 2) // monto bruto a debitar del wallet
  feePct      Decimal          @map("fee_pct") @db.Decimal(6, 5)
  fee         Decimal          @db.Decimal(12, 2)
  net         Decimal          @db.Decimal(12, 2) // amount - fee (lo que recibe el usuario)
  currency    String           @default("GTQ")
  status      WithdrawalStatus @default(pending)
  note        String? // motivo de rechazo / referencia de pago
  decidedById String?          @map("decided_by_id") @db.Uuid // admin que decidiĂł
  decidedAt   DateTime?        @map("decided_at")
  paidAt      DateTime?        @map("paid_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("wallet_withdrawals")
}

/// BitĂˇcora de sincronizaciĂłn para validadores offline (Ola 5, modelo SafeTix).
/// Cada emisiĂłn/transferencia/check-in/revocaciĂłn agrega una entrada; el
/// dispositivo de puerta hace pull incremental (`seq` global monĂłtono) y aplica
/// el Ăşltimo estado por boleto. El secreto TOTP NO se guarda aquĂ­ (se sirve
/// descifrado al armar el manifiesto, sobre TLS y solo a operadores de puerta).
model TicketSyncEntry {
  seq       BigInt          @id @default(autoincrement())
  eventId   String          @map("event_id") @db.Uuid
  ticketId  String          @map("ticket_id") @db.Uuid
  reason    TicketEventType
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([eventId, seq])
  @@map("ticket_sync_entries")
}

/// AsignaciĂłn de un operador de puerta a un evento (Ola 6.5, SafeTix). Un admin o
/// el promotor dueĂ±o la crea; acota quĂ© eventos puede validar cada operador. Se
/// verifica (ademĂˇs del claim `gateEventId` del token de puerta corto) al pedir el
/// manifiesto â†’ defensa en profundidad: revocar la asignaciĂłn corta el acceso.
model GateAssignment {
  id          String   @id @default(uuid()) @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  operatorId  String   @map("operator_id") @db.Uuid
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  event    Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  operator User  @relation("GateOperator", fields: [operatorId], references: [id], onDelete: Cascade)

  @@unique([eventId, operatorId])
  @@index([operatorId])
  @@map("gate_assignments")
}

enum ValidatorStatus {
  active
  disabled
}

/// Validador de boletos invitado por email (feature Validadores). El promotor pone
/// un email â†’ se crea un User LIGERO con rol gate_operator + un `gate_assignment`
/// (reusa toda la infra SafeTix: manifiesto/verify/checkins) + esta invitaciĂłn con
/// cĂłdigo de un solo uso y token de magic-link (ambos hasheados). El link abre el
/// validador directo (sin cuenta completa); vale solo mientras `status=active` y la
/// asignaciĂłn siga viva. Deshabilitar (uno o todos) revoca la asignaciĂłn y corta el
/// manifiesto/token.
model ValidatorInvitation {
  id          String          @id @default(uuid()) @db.Uuid
  eventId     String          @map("event_id") @db.Uuid
  email       String
  operatorId  String          @map("operator_id") @db.Uuid
  codeHash    String          @map("code_hash")
  tokenHash   String          @unique @map("token_hash")
  status      ValidatorStatus @default(active)
  invitedById String          @map("invited_by_id") @db.Uuid
  expiresAt   DateTime        @map("expires_at")
  // SesiĂłn activa "Ăşltimo gana": cada canje (claim) genera un sid que se guarda aquĂ­ y se
  // incrusta en el gate-token; canjear en OTRO dispositivo lo rota â†’ el gate-token anterior
  // deja de poder refrescar el manifiesto o subir check-ins (operaciones ONLINE).
  activeSessionId String?      @map("active_session_id")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  event    Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  operator User  @relation("ValidatorOperator", fields: [operatorId], references: [id], onDelete: Cascade)

  @@unique([eventId, email])
  @@index([eventId])
  @@map("validator_invitations")
}

/// InvitaciĂłn de promotor por token (Ola F4). Un admin o promotor aprobado invita
/// por correo; el destinatario abre la URL con el token, se registra con el email
/// precargado y queda AUTO-APROBADO como promotor (se salta la autorizaciĂłn). El
/// token se guarda hasheado (solo se muestra una vez en la URL).
model PromoterInvitation {
  id               String                   @id @default(uuid()) @db.Uuid
  email            String
  tokenHash        String                   @unique @map("token_hash")
  status           PromoterInvitationStatus @default(pending)
  /// Marca al invitado como usuario de PRUEBA: al aceptar, su User queda con
  /// isTestUser=true (anclado a Sandbox, no usa pasarelas reales).
  isTestUser       Boolean                  @default(false) @map("is_test_user")
  invitedById      String                   @map("invited_by_id") @db.Uuid
  acceptedByUserId String?                  @map("accepted_by_user_id") @db.Uuid
  expiresAt        DateTime                 @map("expires_at")
  acceptedAt       DateTime?                @map("accepted_at")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")

  invitedBy User @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([invitedById])
  @@map("promoter_invitations")
}

/// InvitaciĂłn de ASESOR (T7). Un admin invita por correo. Si el usuario YA existe, el
/// link CONFIRMA la subida a rol asesor; si NO existĂ­a, se crea el User (sin password)
/// y el link lleva a FIJAR CONTRASEĂ‘A. `createdUserId` guarda el usuario creado para el
/// caso "nuevo". Reusa PromoterInvitationStatus (pending/accepted/revoked/expired).
model AdvisorInvitation {
  id               String                   @id @default(uuid()) @db.Uuid
  email            String
  tokenHash        String                   @unique @map("token_hash")
  status           PromoterInvitationStatus @default(pending)
  invitedById      String                   @map("invited_by_id") @db.Uuid
  createdUserId    String?                  @map("created_user_id") @db.Uuid
  acceptedByUserId String?                  @map("accepted_by_user_id") @db.Uuid
  expiresAt        DateTime                 @map("expires_at")
  acceptedAt       DateTime?                @map("accepted_at")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")

  invitedBy User @relation("AdvisorInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([invitedById])
  @@map("advisor_invitations")
}

/// Historial APPEND-ONLY de transiciones de estado de un promotor (v3.2). El
/// estado actual sigue en User.promoterStatus; cada cambio (approve/reject/
/// suspend/reactivar) se audita aquĂ­ con quiĂ©n lo hizo y el motivo. Nunca se edita.
model PromoterStatusEvent {
  id         String         @id @default(uuid()) @db.Uuid
  promoterId String         @map("promoter_id") @db.Uuid
  adminId    String?        @map("admin_id") @db.Uuid // quiĂ©n ejecutĂł (null = sistema)
  statusFrom PromoterStatus @map("status_from")
  statusTo   PromoterStatus @map("status_to")
  reason     String?
  createdAt  DateTime       @default(now()) @map("created_at")

  @@index([promoterId])
  @@map("promoter_status_events")
}

// ---------------------------------------------------------------------------
// Salones y plantillas de asientos (v3.5)
// ---------------------------------------------------------------------------

/// SalĂłn/venue reutilizable. Un admin lo gestiona; cualquier promotor lo elige al
/// crear un evento para prefijar direcciĂłn/coordenadas y, opcionalmente, arrancar
/// con un layout de asientos (`seatTemplateId`). No se materializan asientos aquĂ­:
/// solo referencia la geometrĂ­a base que el editor del evento puede aplicar.
model Hall {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  address        String?
  lat            Float?
  lng            Float?
  city           String?
  notes          String?
  seatTemplateId String?  @map("seat_template_id") @db.Uuid
  /// v3.7: draft (solo admin) | published (visible en el selector del promotor).
  status         ContentStatus @default(draft)
  /// v3.10: oculto del selector del promotor sin eliminarlo (reversible).
  hidden         Boolean  @default(false)
  /// v3.10: deshabilitado (prerequisito para poder ELIMINARlo). No sale al promotor.
  disabled       Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  seatTemplate SeatTemplate? @relation(fields: [seatTemplateId], references: [id], onDelete: SetNull)
  events       Event[]

  @@index([name])
  @@index([status])
  @@map("halls")
}

/// Plantilla de disposiciĂłn de asientos (v3.5). Registra los presets del editor
/// (built-in) y las plantillas que el admin cree a mano. `layoutJson` guarda la
/// metadata de presentaciĂłn (icono/hint) o la geometrĂ­a; `params` los parĂˇmetros
/// de generaciĂłn (filas, columnas, radio, etc.). Built-in = no borrable/editable.
model SeatTemplate {
  id         String           @id @default(uuid()) @db.Uuid
  name       String
  kind       SeatTemplateKind @default(custom)
  layoutJson Json             @default("{}") @map("layout_json")
  params     Json?
  isBuiltIn  Boolean          @default(false) @map("is_built_in")
  /// v3.7: draft (solo admin) | published (visible en el desplegable del editor).
  status     ContentStatus    @default(draft)
  /// v3.7: oculta del desplegable del promotor sin eliminarla (reversible).
  hidden     Boolean          @default(false)
  /// v3.7: deshabilitada (prerequisito para poder ELIMINARla). No sale al promotor.
  disabled   Boolean          @default(false)
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  halls Hall[]

  @@index([kind])
  @@index([status])
  @@map("seat_templates")
}

/// BitĂˇcora de auditorĂ­a (v3.8, no-repudio). Registro APPEND-ONLY encadenado por
/// hash (misma tĂ©cnica que el ledger/custody: `prevHash` + `hash=sha256(prevHash+
/// contenido)` + `seq` monĂłtono) de acciones sensibles y de CADA click de
/// confirmaciĂłn del frontend. Captura contexto server-side (IP y user-agent del
/// request, NO del body) para justificar "usted dio click en confirmar". El
/// `userId` se guarda como texto plano SIN FK: la anonimizaciĂłn de un usuario NO
/// debe borrar ni romper su rastro de auditorĂ­a (trazabilidad intacta).
model AuditEvent {
  id        String   @id @default(uuid()) @db.Uuid
  seq       BigInt   @default(autoincrement())
  userId    String?  @map("user_id")
  action    String
  resource  String?
  ip        String?
  userAgent String?  @map("user_agent")
  payload   Json?
  prevHash  String   @map("prev_hash")
  hash      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([createdAt, id])
  @@map("audit_events")
}

/// Registro de correos ENVIADOS (email log). Observabilidad de deliverability +
/// base de la cola (reintentar los que quedaron pendientes). EXCLUYE por diseĂ±o los
/// correos sensibles (OTP/verificaciĂłn/nuevo dispositivo/magic-link): no se registran.
enum EmailStatus {
  queued // encolado (esperando envĂ­o por el worker)
  sent // entregado al SMTP
  failed // direcciĂłn invĂˇlida o error de envĂ­o
}

model EmailLog {
  id            String      @id @default(uuid()) @db.Uuid
  recipient     String // correo destino
  type          String // tipo/plantilla (invitaciĂłn, confirmaciĂłn, notificaciĂłn, â€¦)
  subject       String
  status        EmailStatus @default(queued)
  error         String? // motivo del fallo (direcciĂłn invĂˇlida, error SMTP)
  correlationId String?     @map("correlation_id")
  createdAt     DateTime    @default(now()) @map("created_at")
  sentAt        DateTime?   @map("sent_at")

  @@index([recipient])
  @@index([type])
  @@index([status])
  @@index([createdAt, id])
  @@map("email_logs")
}
